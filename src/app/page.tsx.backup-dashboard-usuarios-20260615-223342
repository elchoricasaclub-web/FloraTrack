    <div className="rounded-3xl border border-slate-300 bg-white p-6 shadow-sm">
      <p className="text-sm font-black text-slate-500">{title}</p>
      <p className="mt-2 text-3xl font-black text-slate-950">{value}</p>
    </div>
  );
}

