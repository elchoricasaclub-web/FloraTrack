  badge,
  active = false,
}: {
  href: string;
  label: string;
  badge: string;
  active?: boolean;
}) {
  return (
    <a
      href={href}
      className={`flex items-center justify-between rounded-2xl px-4 py-3 text-sm font-black transition ${
        active
          ? "bg-emerald-600 text-white shadow-lg shadow-emerald-100"
          : "text-slate-950 hover:bg-slate-100"
      }`}
    >
      <span>{label}</span>
      <span
        className={`rounded-full px-3 py-1 text-xs font-black ${
          active ? "bg-white/20 text-white" : "bg-emerald-100 text-emerald-800"
        }`}
      >
        {badge}
      </span>
    </a>
  );
}

function ExecutiveMetric({
  title,
  value,
  tone = "white",
}: {
  title: string;
  value: string | number;
  tone?: "white" | "emerald" | "red";
}) {
  const valueClass =
    tone === "emerald"
      ? "text-emerald-300"
      : tone === "red"
      ? "text-red-300"
      : "text-white";

  return (
    <div className="rounded-3xl bg-white/10 p-6">
      <p className="text-sm font-black text-slate-200">{title}</p>
      <p className={`mt-3 text-5xl font-black ${valueClass}`}>{value}</p>
    </div>
  );
}

function MiniMetric({ title, value }: { title: string; value: string | number }) {
