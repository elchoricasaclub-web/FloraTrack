"use client";

import { useEffect, useMemo, useState } from "react";
import {
  ActionButton,
  DetailDrawer,
  EmptyState,
  FilterChips,
  ItemCard,
  MetricCard,
  ModuleCard,
  NotificationCard,
  SearchBar,
  SkeletonCard,
} from "../components/floratrack/PremiumUI";
import {
  heroAccess,
  primaryModules,
  quickAccess,
  secondaryModules,
  type ModuleItem,
} from "../lib/floratrackModules";

const filters = [
  "Todos",
  "Críticos",
  "QA/GMP",
  "Operación",
  "Sistema",
  "Regulatorio",
  "Automatización",
];

function moduleMatchesFilter(module: ModuleItem, filter: string) {
  if (filter === "Todos") return true;
  if (filter === "Críticos") return ["Alto", "Crítico"].includes(module.risk);
  if (filter === "QA/GMP") return ["QA", "GMP", "Audit", "eSign", "Validation", "Risk", "Change"].includes(module.group);
  if (filter === "Operación") return ["GACP", "Base", "Supplier", "Sanitation", "Pest", "Waste", "Stability", "Recall"].includes(module.group);
  if (filter === "Sistema") return ["Security", "Backup", "Integrations", "DataOps", "Workflow"].includes(module.group);
  if (filter === "Regulatorio") return ["Regulatory", "RegulatoryApi", "Company", "GIS"].includes(module.group);
  if (filter === "Automatización") return ["Automation", "ReportAutomation", "Notifications", "Reports"].includes(module.group);

  return true;
}

export default function DashboardPage() {
  const [search, setSearch] = useState("");
  const [activeFilter, setActiveFilter] = useState("Todos");
  const [selectedModule, setSelectedModule] = useState<ModuleItem | null>(null);
  const [isSearching, setIsSearching] = useState(false);

  useEffect(() => {
    setIsSearching(true);
    const timer = window.setTimeout(() => setIsSearching(false), 180);
    return () => window.clearTimeout(timer);
  }, [search, activeFilter]);

  const filteredModules = useMemo(() => {
    const term = search.trim().toLowerCase();

    return primaryModules.filter((module) => {
      const matchesSearch =
        !term ||
        [
          module.title,
          module.subtitle,
          module.description,
          module.tag,
          module.status,
          module.group,
          module.risk,
        ]
          .join(" ")
          .toLowerCase()
          .includes(term);

      return matchesSearch && moduleMatchesFilter(module, activeFilter);
    });
  }, [search, activeFilter]);

  const metrics = useMemo(() => {
    const critical = primaryModules.filter((module) => module.risk === "Crítico").length;
    const high = primaryModules.filter((module) => module.risk === "Alto").length;
    const qa = primaryModules.filter((module) => ["QA", "GMP", "Audit", "Validation", "eSign"].includes(module.group)).length;

    return {
      score: 99,
      active: primaryModules.length,
      critical,
      high,
      qa,
      validation: Math.min(100, Math.round(((primaryModules.length - critical) / primaryModules.length) * 100)),
    };
  }, []);

  const recentHighlights = useMemo(() => {
    return primaryModules
      .filter((module) => ["Crítico", "Alto"].includes(module.risk))
      .slice(0, 5);
  }, []);

  return (
    <main className="min-h-screen text-slate-950">
      <div className="grid min-h-screen lg:grid-cols-[310px_1fr]">
        <aside className="sticky top-0 hidden h-screen overflow-hidden border-r border-slate-200 bg-white/85 backdrop-blur-xl lg:block">
          <div className="flex h-full flex-col">
            <header className="border-b border-slate-200 p-6">
              <div className="flex items-center gap-4">
                <div className="relative flex h-14 w-14 items-center justify-center rounded-3xl bg-gradient-to-br from-emerald-500 to-cyan-400 text-2xl font-black text-white shadow-xl shadow-emerald-100">
                  F
                  <span className="absolute -right-1 -top-1 h-4 w-4 rounded-full border-2 border-white bg-emerald-400" />
                </div>

                <div>
                  <h1 className="text-2xl font-black tracking-tight">FloraTrack</h1>
                  <p className="text-xs font-black uppercase tracking-[0.25em] text-emerald-700">Enterprise</p>
                </div>
              </div>

              <div className="mt-6">
                <SearchBar value={search} onChange={setSearch} placeholder="Buscar módulo..." />
              </div>
            </header>

            <nav className="ft-scrollbar flex-1 overflow-auto p-4">
              <p className="mb-3 px-3 text-xs font-black uppercase tracking-[0.22em] text-slate-400">Módulos</p>

              <div className="space-y-1">
                <a href="/" className="flex items-center justify-between rounded-2xl bg-slate-950 px-4 py-3 text-sm font-black text-white shadow-lg">
                  <span>Dashboard</span>
                  <span className="rounded-full bg-white/15 px-3 py-1 text-xs">Inicio</span>
                </a>

                {primaryModules.map((module) => (
                  <a key={module.href} href={module.href} className="group flex items-center justify-between gap-3 rounded-2xl px-4 py-3 text-sm font-black text-slate-700 transition hover:bg-slate-100 hover:text-slate-950">
                    <span className="line-clamp-2">{module.title}</span>
                    <span className="shrink-0 rounded-full bg-emerald-100 px-2.5 py-1 text-[11px] font-black text-emerald-800 group-hover:bg-slate-950 group-hover:text-white">
                      {module.tag}
                    </span>
                  </a>
                ))}
              </div>

              <div className="mt-8 rounded-[1.5rem] border border-slate-200 bg-slate-50 p-4">
                <p className="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Roadmap</p>
                <div className="mt-3 space-y-2">
                  {secondaryModules.map((item) => (
                    <div key={item} className="rounded-2xl bg-white px-4 py-3 text-xs font-black text-slate-500 shadow-sm">
                      {item}
                    </div>
                  ))}
                </div>
              </div>
            </nav>
          </div>
        </aside>

        <section className="ft-scrollbar max-h-screen overflow-auto">
          <header className="sticky top-0 z-40 border-b border-slate-200 bg-white/80 px-5 py-4 backdrop-blur-xl md:px-8">
            <div className="flex flex-col gap-4 xl:flex-row xl:items-center xl:justify-between">
              <div>
                <p className="text-xs font-black uppercase tracking-[0.28em] text-emerald-700">FloraTrack</p>
                <h2 className="text-3xl font-black tracking-tight md:text-5xl">Command Center</h2>
              </div>

              <div className="flex gap-2 overflow-x-auto pb-1">
                {quickAccess.map((item) => (
                  <a
                    key={item.href}
                    href={item.href}
                    className={`shrink-0 rounded-2xl bg-gradient-to-r ${item.className} px-5 py-3 text-sm font-black text-white shadow-lg transition hover:-translate-y-0.5`}
                  >
                    {item.label}
                  </a>
                ))}
              </div>
            </div>
          </header>

          <div className="space-y-8 p-5 md:p-8">
            <section className="ft-dark-glass relative overflow-hidden rounded-[2.25rem] p-6 text-white md:p-9">
              <div className="absolute right-8 top-8 h-28 w-28 rounded-full bg-emerald-400/20 blur-3xl" />
              <div className="absolute bottom-0 right-1/4 h-24 w-24 rounded-full bg-cyan-400/20 blur-3xl" />

              <div className="relative grid gap-8 xl:grid-cols-[1fr_320px] xl:items-center">
                <div>
                  <div className="inline-flex rounded-full border border-emerald-300/30 bg-emerald-300/10 px-4 py-2 text-xs font-black uppercase tracking-[0.25em] text-emerald-200">
                    Premium Compliance OS
                  </div>

                  <h3 className="mt-6 max-w-5xl text-5xl font-black tracking-tight md:text-7xl">
                    Trazabilidad GACP/GMP sin fricción.
                  </h3>

                  <p className="mt-5 max-w-4xl text-base font-semibold leading-8 text-slate-300 md:text-lg">
                    Plataforma Enterprise para QA, registros electrónicos, firmas, riesgos,
                    reportes programados, integridad de datos, auditoría, control de cambios,
                    APIs regulatorias y operación farmacéutica del cannabis medicinal.
                  </p>

                  <div className="mt-7 flex flex-wrap gap-3">
                    <ActionButton href="/reportes-programados" variant="dark">Automatizar reportes</ActionButton>
                    <ActionButton href="/riesgos" variant="secondary">Ver matriz de riesgos</ActionButton>
                  </div>
                </div>

                <div className="space-y-3">
                  {heroAccess.map((item) => (
                    <a
                      key={item.href}
                      href={item.href}
                      className={`block rounded-3xl bg-gradient-to-r ${item.className} px-6 py-5 text-center text-base font-black text-white shadow-xl transition hover:-translate-y-1`}
                    >
                      {item.label}
                    </a>
                  ))}
                </div>
              </div>
            </section>

            <section className="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
              <MetricCard label="Score ejecutivo" value={`${metrics.score}%`} description="Madurez global de plataforma" tone="emerald" progress={metrics.score} />
              <MetricCard label="Módulos activos" value={metrics.active} description="Componentes disponibles" tone="sky" progress={100} />
              <MetricCard label="Riesgo crítico" value={metrics.critical} description="Módulos con criticidad alta" tone="rose" progress={Math.min(100, metrics.critical * 8)} />
              <MetricCard label="QA/GMP" value={metrics.qa} description="Módulos de cumplimiento" tone="violet" progress={metrics.validation} />
            </section>

            <section className="grid gap-6 xl:grid-cols-[1fr_380px]">
              <div className="space-y-5">
                <div className="flex flex-col gap-4 xl:flex-row xl:items-end xl:justify-between">
                  <div>
                    <p className="text-xs font-black uppercase tracking-[0.25em] text-slate-400">Módulos activos</p>
                    <h3 className="mt-2 text-3xl font-black tracking-tight md:text-4xl">Arquitectura FloraTrack</h3>
                  </div>

                  <p className="text-sm font-black text-slate-500">{filteredModules.length} módulos visibles</p>
                </div>

                <div className="space-y-4 rounded-[2rem] border border-slate-200 bg-white/70 p-4 backdrop-blur">
                  <FilterChips filters={filters} active={activeFilter} onChange={setActiveFilter} />
                </div>

                {isSearching ? (
                  <div className="grid gap-5 xl:grid-cols-2">
                    <SkeletonCard />
                    <SkeletonCard />
                    <SkeletonCard />
                    <SkeletonCard />
                  </div>
                ) : filteredModules.length === 0 ? (
                  <EmptyState
                    title="No hay módulos con ese filtro"
                    description="Ajusta la búsqueda o cambia los chips de filtro para encontrar el módulo que necesitas."
                    action={<ActionButton onClick={() => { setSearch(""); setActiveFilter("Todos"); }}>Limpiar filtros</ActionButton>}
                  />
                ) : (
                  <div className="grid gap-5 xl:grid-cols-2">
                    {filteredModules.map((module, index) => (
                      <ModuleCard
                        key={module.href}
                        module={module}
                        index={index}
                        featured={index < 2 && activeFilter === "Todos"}
                        onInspect={() => setSelectedModule(module)}
                      />
                    ))}
                  </div>
                )}
              </div>

              <aside className="space-y-5">
                <section className="rounded-[2rem] border border-slate-200 bg-white p-5 shadow-sm">
                  <div className="flex items-center justify-between">
                    <div>
                      <p className="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Actividad</p>
                      <h3 className="mt-1 text-2xl font-black text-slate-950">Prioridad QA</h3>
                    </div>
                    <span className="ft-pulse-soft h-3 w-3 rounded-full bg-emerald-500" />
                  </div>

                  <div className="mt-5 space-y-3">
                    <NotificationCard title="Reportes programados" description="Automatiza reportes ejecutivos, QA, CAPA y riesgos con revisión controlada." tone="blue" />
                    <NotificationCard title="Riesgos GxP" description="Matriz de RPN, mitigación, eficacia y decisión QA activa." tone="rose" />
                    <NotificationCard title="Control de cambios" description="Evalúa impacto documental, entrenamiento, validación y regulación." tone="cyan" />
                  </div>
                </section>

                <section className="rounded-[2rem] border border-slate-200 bg-white p-5 shadow-sm">
                  <p className="text-xs font-black uppercase tracking-[0.2em] text-slate-400">Destacados</p>
                  <div className="mt-5 space-y-4">
                    {recentHighlights.map((module) => (
                      <ItemCard
                        key={module.href}
                        title={module.title}
                        description={module.subtitle}
                        meta={`Riesgo ${module.risk} · ${module.tag}`}
                        status={module.status}
                        tone={module.risk === "Crítico" ? "rose" : "amber"}
                        href={module.href}
                      />
                    ))}
                  </div>
                </section>
              </aside>
            </section>
          </div>
        </section>
      </div>

      <nav className="fixed bottom-3 left-3 right-3 z-50 grid grid-cols-4 gap-2 rounded-[1.5rem] border border-slate-200 bg-white/90 p-2 shadow-2xl backdrop-blur-xl lg:hidden">
        <a href="/" className="rounded-2xl bg-slate-950 px-3 py-3 text-center text-xs font-black text-white">Inicio</a>
        <a href="/riesgos" className="rounded-2xl px-3 py-3 text-center text-xs font-black text-slate-700">Riesgos</a>
        <a href="/reportes-programados" className="rounded-2xl px-3 py-3 text-center text-xs font-black text-slate-700">Reportes</a>
        <a href="/workflows" className="rounded-2xl px-3 py-3 text-center text-xs font-black text-slate-700">QA</a>
      </nav>

      <DetailDrawer module={selectedModule} onClose={() => setSelectedModule(null)} />
    </main>
  );
}
