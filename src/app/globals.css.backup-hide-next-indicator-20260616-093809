@import "tailwindcss";

:root {
  --ft-bg: #f4f7fb;
  --ft-surface: rgba(255, 255, 255, 0.86);
  --ft-surface-strong: #ffffff;
  --ft-ink: #06111f;
  --ft-muted: #64748b;
  --ft-border: rgba(15, 23, 42, 0.12);
  --ft-brand: #00a86b;
  --ft-brand-2: #00d4ff;
  --ft-danger: #ff3b5c;
  --ft-warning: #f59e0b;
  --ft-info: #38bdf8;
  --ft-radius-xl: 28px;
  --ft-radius-2xl: 36px;
  --ft-shadow-soft: 0 18px 70px rgba(15, 23, 42, 0.10);
  --ft-shadow-glow: 0 24px 90px rgba(0, 168, 107, 0.20);
}

* {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
}

body {
  min-height: 100vh;
  margin: 0;
  background:
    radial-gradient(circle at top left, rgba(0, 212, 255, 0.16), transparent 32rem),
    radial-gradient(circle at top right, rgba(0, 168, 107, 0.16), transparent 28rem),
    linear-gradient(180deg, #f8fafc 0%, #edf4f8 45%, #f8fafc 100%);
  color: var(--ft-ink);
  font-feature-settings: "ss01", "ss02", "cv01", "cv03";
  text-rendering: geometricPrecision;
}

::selection {
  background: rgba(0, 168, 107, 0.22);
  color: #020617;
}

button,
a,
input,
select,
textarea {
  -webkit-tap-highlight-color: transparent;
}

.ft-glass {
  background: rgba(255, 255, 255, 0.76);
  border: 1px solid rgba(15, 23, 42, 0.10);
  box-shadow: 0 20px 80px rgba(15, 23, 42, 0.08);
  backdrop-filter: blur(22px);
}

.ft-dark-glass {
  background:
    radial-gradient(circle at 18% 10%, rgba(16, 185, 129, 0.20), transparent 26rem),
    radial-gradient(circle at 80% 0%, rgba(56, 189, 248, 0.18), transparent 25rem),
    linear-gradient(135deg, #020617 0%, #07111f 58%, #06121f 100%);
  border: 1px solid rgba(148, 163, 184, 0.22);
  box-shadow: 0 24px 120px rgba(2, 6, 23, 0.36);
}

.ft-grid-bg {
  background-image:
    linear-gradient(rgba(15, 23, 42, 0.045) 1px, transparent 1px),
    linear-gradient(90deg, rgba(15, 23, 42, 0.045) 1px, transparent 1px);
  background-size: 28px 28px;
}

.ft-card-hover {
  transition:
    transform 220ms ease,
    box-shadow 220ms ease,
    border-color 220ms ease,
    background-color 220ms ease;
}

.ft-card-hover:hover {
  transform: translateY(-4px);
  box-shadow: 0 22px 80px rgba(15, 23, 42, 0.12);
}

.ft-scrollbar {
  scrollbar-width: thin;
  scrollbar-color: rgba(15, 23, 42, 0.25) transparent;
}

.ft-scrollbar::-webkit-scrollbar {
  width: 10px;
  height: 10px;
}

.ft-scrollbar::-webkit-scrollbar-thumb {
  background: rgba(15, 23, 42, 0.18);
  border-radius: 999px;
  border: 3px solid transparent;
  background-clip: content-box;
}

.ft-scrollbar::-webkit-scrollbar-thumb:hover {
  background: rgba(15, 23, 42, 0.32);
  border: 3px solid transparent;
  background-clip: content-box;
}

.ft-enter {
  animation: ft-enter 420ms ease both;
}

.ft-pulse-soft {
  animation: ft-pulse-soft 2.6s ease-in-out infinite;
}

@keyframes ft-enter {
  from {
    opacity: 0;
    transform: translateY(14px) scale(0.985);
  }
  to {
    opacity: 1;
    transform: translateY(0) scale(1);
  }
}

@keyframes ft-pulse-soft {
  0%, 100% {
    opacity: 0.72;
    transform: scale(1);
  }
  50% {
    opacity: 1;
    transform: scale(1.025);
  }
}

@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.001ms !important;
    animation-iteration-count: 1 !important;
    scroll-behavior: auto !important;
    transition-duration: 0.001ms !important;
  }
}
