import { NextResponse } from "next/server";
import fs from "fs";
import path from "path";
import { validateRecord } from "../../../lib/recordValidation";

export const runtime = "nodejs";
export const dynamic = "force-dynamic";

const dataDir = path.join(process.cwd(), "data");
const dataFile = path.join(dataDir, "propagacion.json");

const seedPropagacion = [
  {
    id: "PROP-001",
    createdAt: new Date().toISOString(),
    nombre: "Banco de Plantas Madre",
    codigo: "PROP-001",
    genetica: "Genética principal",
    area: "Propagación",
    responsable: "Responsable GACP",
    fase: "Madres",
    estado: "Activo",
    riesgo: "Medio",
    cantidad: 24,
    avance: 78,
    evidencia: "Registro madres / sanidad / genética",
    nota: "Control de plantas madre, vigor, sanidad, codificación genética, ubicación y trazabilidad de material vegetal."
  }
];

function ensureStore() {
  if (!fs.existsSync(dataDir)) fs.mkdirSync(dataDir, { recursive: true });
  if (!fs.existsSync(dataFile)) fs.writeFileSync(dataFile, JSON.stringify(seedPropagacion, null, 2), "utf8");
}

function readRecords() {
  ensureStore();
  try {
    return JSON.parse(fs.readFileSync(dataFile, "utf8"));
  } catch {
    return [];
  }
}

function writeRecords(records: any[]) {
  ensureStore();
  fs.writeFileSync(dataFile, JSON.stringify(records, null, 2), "utf8");
}

export async function GET() {
  const records = readRecords();
  return NextResponse.json({ ok: true, total: records.length, records });
}

export async function POST(request: Request) {
  const body = await request.json();

  const missing = validateRecord(body, [
    { key: "nombre", label: "Nombre del registro" },
    { key: "codigo", label: "Código" },
    { key: "genetica", label: "Genética", disallow: ["sin genética asignada", "sin genetica asignada"] },
    { key: "area", label: "Área" },
    { key: "responsable", label: "Responsable", disallow: ["responsable gacp", "usuario actual"] },
    { key: "fase", label: "Fase" },
    { key: "estado", label: "Estado" },
    { key: "riesgo", label: "Riesgo" },
    { key: "cantidad", label: "Cantidad de material vegetal", minNumber: 1 },
    { key: "evidencia", label: "Evidencia", disallow: ["evidencia pendiente"] },
    { key: "nota", label: "Nota técnica" }
  ]);

  if (missing.length > 0) {
    return NextResponse.json({
      ok: false,
      error: "VALIDATION_REQUIRED",
      message: "Falta información requerida.",
      fields: missing
    }, { status: 400 });
  }

  const records = readRecords();

  const record = {
    id: `PROP-${Date.now()}`,
    createdAt: new Date().toISOString(),
    nombre: String(body.nombre),
    codigo: String(body.codigo),
    genetica: String(body.genetica),
    area: String(body.area),
    responsable: String(body.responsable),
    fase: String(body.fase),
    estado: String(body.estado),
    riesgo: String(body.riesgo),
    cantidad: Number(body.cantidad),
    avance: Number(body.avance || 0),
    evidencia: String(body.evidencia),
    nota: String(body.nota)
  };

  records.unshift(record);
  writeRecords(records);

  return NextResponse.json({ ok: true, record, records });
}

export async function PATCH(request: Request) {
  const body = await request.json();
  const records = readRecords();

  const updated = records.map((item: any) => {
    if (item.id !== body.id) return item;
    return { ...item, ...body, updatedAt: new Date().toISOString() };
  });

  writeRecords(updated);

  return NextResponse.json({ ok: true, records: updated });
}
