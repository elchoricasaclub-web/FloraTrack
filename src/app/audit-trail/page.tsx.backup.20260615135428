"use client";

import { useEffect, useState } from "react";

type ActionRecord = {
  id: string;
  createdAt: string;
  label: string;
  moduleName: string;
  actionType: string;
  route?: string;
  note?: string;
};

export default function AuditTrailPage() {
  const [actions, setActions] = useState<ActionRecord[]>([]);
  const [loading, setLoading] = useState(true);

  async function loadActions() {
    setLoading(true);

    try {
      const response = await fetch("/api/button-actions", {
        cache: "no-store"
      });

      const data = await response.json();

      if (data.ok) {
        setActions(data.actions || []);
      }
    } finally {
      setLoading(false);
    }
  }

  useEffect(() => {
    loadActions();
  }, []);

  return (
    <main className="min-h-screen bg-slate-50 p-8">
      <section className="rounded-[2rem] bg-slate-950 p-10 text-white shadow-2xl">
        <div className="text-xs font-black uppercase tracking-widest text-green-400">
          FloraTrack · Audit Trail
        </div>

        <h1 className="mt-3 text-6xl font-black">
          Audit Trail
        </h1>

        <p className="mt-4 max-w-4xl text-slate-300">
          Trazabilidad de acciones, navegación, eventos de usuario, botones ejecutados y evidencias funcionales de la plataforma.
        </p>

        <div className="mt-8 grid grid-cols-4 gap-4">
          <div className="rounded-3xl bg-white/10 p-5">
            <div className="text-xs font-black uppercase text-slate-400">Eventos</div>
            <div className="mt-2 text-4xl font-black">{actions.length}</div>
          </div>

          <div className="rounded-3xl bg-white/10 p-5">
            <div className="text-xs font-black uppercase text-slate-400">Navegación</div>
            <div className="mt-2 text-4xl font-black">
              {actions.filter((item) => item.actionType === "navigation").length}
            </div>
          </div>

          <div className="rounded-3xl bg-white/10 p-5">
            <div className="text-xs font-black uppercase text-slate-400">Exportaciones</div>
            <div className="mt-2 text-4xl font-black">
              {actions.filter((item) => item.actionType === "export").length}
            </div>
          </div>

          <div className="rounded-3xl bg-white/10 p-5">
            <div className="text-xs font-black uppercase text-slate-400">Estado</div>
            <div className="mt-2 text-4xl font-black text-green-400">Activo</div>
          </div>
        </div>

        <div className="mt-8 flex flex-wrap gap-3">
          <button
            type="button"
            onClick={loadActions}
            className="rounded-2xl bg-green-600 px-6 py-4 font-black text-white"
          >
            Actualizar Audit Trail
          </button>

          <a
            href="/"
            className="rounded-2xl border border-white/20 px-6 py-4 font-black text-white"
          >
            Volver al Dashboard
          </a>

          <a
            href="/progress-records"
            className="rounded-2xl border border-white/20 px-6 py-4 font-black text-white"
          >
            Ver avances
          </a>
        </div>
      </section>

      <section className="mt-8 rounded-3xl border bg-white p-6 shadow-sm">
        <div className="flex items-center justify-between gap-4">
          <div>
            <div className="text-xs font-black uppercase tracking-widest text-green-600">
              Historial auditado
            </div>

            <h2 className="mt-2 text-3xl font-black text-slate-900">
              Eventos registrados
            </h2>
          </div>

          <button
            type="button"
            onClick={loadActions}
            className="rounded-2xl border px-5 py-3 font-black text-slate-700"
          >
            Actualizar
          </button>
        </div>

        {loading ? (
          <div className="mt-6 rounded-2xl bg-slate-50 p-6 font-bold text-slate-500">
            Cargando Audit Trail...
          </div>
        ) : actions.length === 0 ? (
          <div className="mt-6 rounded-2xl bg-slate-50 p-6 font-bold text-slate-500">
            Todavía no hay eventos registrados. Vuelve al Dashboard y presiona algunos botones.
          </div>
        ) : (
          <div className="mt-6 overflow-hidden rounded-3xl border">
            <table className="w-full border-collapse text-left text-sm">
              <thead className="bg-slate-100 text-xs uppercase tracking-widest text-slate-500">
                <tr>
                  <th className="p-4">Fecha</th>
                  <th className="p-4">Módulo</th>
                  <th className="p-4">Acción</th>
                  <th className="p-4">Tipo</th>
                  <th className="p-4">Ruta</th>
                  <th className="p-4">Nota</th>
                </tr>
              </thead>

              <tbody>
                {actions.map((action) => (
                  <tr key={action.id} className="border-t">
                    <td className="p-4 font-semibold text-slate-600">
                      {new Date(action.createdAt).toLocaleString()}
                    </td>

                    <td className="p-4 font-bold text-slate-900">
                      {action.moduleName}
                    </td>

                    <td className="p-4 font-bold text-slate-900">
                      {action.label}
                    </td>

                    <td className="p-4 font-semibold text-slate-600">
                      {action.actionType}
                    </td>

                    <td className="p-4 break-all font-semibold text-slate-600">
                      {action.route || "Sin ruta"}
                    </td>

                    <td className="p-4 font-semibold text-slate-600">
                      {action.note || "Evento registrado."}
                    </td>
                  </tr>
                ))}
              </tbody>
            </table>
          </div>
        )}
      </section>
    </main>
  );
}
