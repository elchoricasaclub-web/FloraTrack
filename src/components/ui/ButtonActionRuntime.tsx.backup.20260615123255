"use client";

import { useEffect } from "react";

type ButtonActionPayload = {
  label: string;
  moduleName: string;
  actionType: string;
  route?: string;
  note?: string;
};

function clean(value: string) {
  return value.replace(/\s+/g, " ").trim();
}

function normalize(value: string) {
  return clean(value).toLowerCase();
}

function pageModule() {
  if (typeof document === "undefined") return "FloraTrack";

  return (
    document.querySelector("header h1")?.textContent?.trim() ||
    document.querySelector("main h1")?.textContent?.trim() ||
    document.querySelector("main h2")?.textContent?.trim() ||
    document.querySelector("section h1")?.textContent?.trim() ||
    "FloraTrack"
  );
}

async function logAction(payload: ButtonActionPayload) {
  try {
    await fetch("/api/button-actions", {
      method: "POST",
      headers: {
        "Content-Type": "application/json"
      },
      body: JSON.stringify(payload)
    });
  } catch {
    // No bloquea la app si el log falla.
  }
}

function exportCurrentView(label: string) {
  const payload = {
    exportedAt: new Date().toISOString(),
    source: "FloraTrack",
    action: label,
    moduleName: pageModule(),
    pageTitle: document.title,
    url: window.location.href,
    visibleText: document.body.innerText.slice(0, 12000)
  };

  const blob = new Blob([JSON.stringify(payload, null, 2)], {
    type: "application/json"
  });

  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");
  const filename = `floratrack_export_${Date.now()}.json`;

  link.href = url;
  link.download = filename;
  link.click();

  URL.revokeObjectURL(url);
}

function goTo(route: string) {
  window.location.href = route;
}

function handleKnownButton(labelRaw: string) {
  const label = clean(labelRaw);
  const value = normalize(label);
  const moduleName = pageModule();

  if (!value) return false;

  if (value.includes("guardar")) return false;
  if (value.includes("cerrar")) return false;
  if (value.includes("entendido")) return false;

  if (value === "nuevo registro" || value === "+ nuevo registro") {
    logAction({
      label,
      moduleName,
      actionType: "navigation",
      route: "/new-record",
      note: "Nuevo Registro conectado por ButtonActionRuntime"
    });

    goTo("/new-record");
    return true;
  }

  if (value.includes("audit trail")) {
    logAction({
      label,
      moduleName,
      actionType: "navigation",
      route: "/audit-trail",
      note: "Audit Trail abierto desde botón"
    });

    goTo("/audit-trail");
    return true;
  }

  if (value === "registros" || value === "ver registros") {
    logAction({
      label,
      moduleName,
      actionType: "navigation",
      route: "/progress-records",
      note: "Registros abiertos desde botón"
    });

    goTo("/progress-records");
    return true;
  }

  if (value.includes("crear capa")) {
    logAction({
      label,
      moduleName,
      actionType: "navigation",
      route: "/new-record?module=CAPA&type=AccionCorrectiva",
      note: "Creación CAPA conectada"
    });

    goTo("/new-record?module=CAPA&type=AccionCorrectiva");
    return true;
  }

  if (value.includes("exportar")) {
    logAction({
      label,
      moduleName,
      actionType: "export",
      note: "Exportación JSON de vista actual"
    });

    exportCurrentView(label);
    return true;
  }

  if (
    value.includes("ver detalle") ||
    value.includes("ver riesgos") ||
    value.includes("ver operaciones") ||
    value.includes("acciones")
  ) {
    const route = `/action-center?label=${encodeURIComponent(label)}&module=${encodeURIComponent(moduleName)}`;

    logAction({
      label,
      moduleName,
      actionType: "navigation",
      route,
      note: "Acción revisada en Action Center"
    });

    goTo(route);
    return true;
  }

  if (value.includes("actualizar dashboard") || value === "actualizar") {
    logAction({
      label,
      moduleName,
      actionType: "refresh",
      note: "Actualización de vista"
    });

    window.location.reload();
    return true;
  }

  return false;
}

export default function ButtonActionRuntime() {
  useEffect(() => {
    function onClick(event: MouseEvent) {
      const target = event.target as HTMLElement | null;
      if (!target) return;

      const button = target.closest("button") as HTMLButtonElement | null;
      if (!button) return;

      const label =
        button.textContent ||
        button.getAttribute("aria-label") ||
        button.title ||
        "";

      const handled = handleKnownButton(label);

      if (handled) {
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();
      }
    }

    document.addEventListener("click", onClick, true);

    return () => {
      document.removeEventListener("click", onClick, true);
    };
  }, []);

  return null;
}
