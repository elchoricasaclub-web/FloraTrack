  code      String
  batchCode String?
  step      String?
  operator  String?
  parameter String?
  result    String?
  status    String   @default("En proceso")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PackagingRecord {
  id            String   @id @default(cuid())
  code          String
  batchCode     String?
