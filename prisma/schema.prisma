  notes      String?
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt
}

model AuditPackageItem {
  id           String   @id @default(cuid())
  code         String
  packageCode  String?
  module       String?
  evidenceCode String?
  title        String
  status       String   @default("Pendiente")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model ProductionOrder {
  id          String    @id @default(cuid())
  code        String
  productName String
  processType String    @default("Derivado")
  batchSize   Float?
  unit        String?
  responsible String?
  status      String    @default("Planificada")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ProductionBatch {
  id             String    @id @default(cuid())
  code           String
  productName    String
  geneticName    String?
  sourceLot      String?
  productionDate DateTime?
  quantity       Float?
