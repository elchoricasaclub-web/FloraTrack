  description String?
  severity    String    @default("Media")
  status      String    @default("Abierto")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model DataIntegrityReview {
  id          String    @id @default(cuid())
  code        String
  principle   String
  finding     String?
  evidence    String?
  score       Float?
  responsible String?
  status      String    @default("Abierta")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ComplianceRequirement {
  id          String   @id @default(cuid())
  code        String
  standard    String
  chapter     String?
  requirement String
  area        String?
  criticality String   @default("Media")
