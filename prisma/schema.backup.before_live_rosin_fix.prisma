generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model Company {
  id        String   @id @default(cuid())
  name      String
  nit       String?
  city      String?
  status    String   @default("Activa")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users              User[]
  farms              Farm[]
  regulatoryLicenses RegulatoryLicense[]
  quotas             Quota[]
  peasRecords        PeasRecord[]
  invimaProcedures   InvimaProcedure[]
  expirations        Expiration[]
}

model User {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  role      String
  status    String   @default("Activo")
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Farm {
  id        String   @id @default(cuid())
  name      String
  city      String?
  areaHa    Float?
  status    String   @default("Activo")
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  crops     Crop[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Genetic {
  id        String   @id @default(cuid())
  name      String
  origin    String?
  type      String?
  status    String   @default("Autorizada")
  crops     Crop[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Crop {
  id        String    @id @default(cuid())
  code      String
  stage     String
  status    String    @default("Activo")
  farmId    String?
  geneticId String?
  farm      Farm?     @relation(fields: [farmId], references: [id])
  genetic   Genetic?  @relation(fields: [geneticId], references: [id])
  harvests  Harvest[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Harvest {
  id        String   @id @default(cuid())
  code      String
  wetWeight Float?
  status    String   @default("Pendiente")
  cropId    String?
  crop      Crop?    @relation(fields: [cropId], references: [id])
  samples   Sample[]
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Sample {
  id        String     @id @default(cuid())
  code      String
  type      String?
  status    String     @default("Pendiente")
  harvestId String?
  harvest   Harvest?   @relation(fields: [harvestId], references: [id])
  analyses  Analysis[]
  createdAt DateTime   @default(now())
  updatedAt DateTime   @updatedAt
}

model Analysis {
  id        String   @id @default(cuid())
  code      String
  type      String?
  result    String?
  status    String   @default("Pendiente")
  sampleId  String?
  sample    Sample?  @relation(fields: [sampleId], references: [id])
  coa       COA?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model COA {
  id         String   @id @default(cuid())
  code       String
  result     String?
  status     String   @default("Pendiente")
  analysisId String   @unique
  analysis   Analysis @relation(fields: [analysisId], references: [id])
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RegulatoryLicense {
  id        String    @id @default(cuid())
  number    String
  type      String
  authority String?
  status    String    @default("Vigente")
  expiresAt DateTime?
  companyId String?
  company   Company?  @relation(fields: [companyId], references: [id])
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Quota {
  id        String   @id @default(cuid())
  code      String
  type      String
  amount    Float?
  status    String   @default("Solicitado")
  companyId String?
  company   Company? @relation(fields: [companyId], references: [id])
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PeasRecord {
  id          String   @id @default(cuid())
  code        String
  geneticName String?
  amount      Float?
  status      String   @default("Borrador")
  companyId   String?
  company     Company? @relation(fields: [companyId], references: [id])
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model IcaRecord {
  id          String   @id @default(cuid())
  code        String
  geneticName String?
  holder      String?
  status      String   @default("Borrador")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model InvimaProcedure {
  id           String   @id @default(cuid())
  filingNumber String
  product      String
  category     String?
  status       String   @default("Borrador")
  companyId    String?
  company      Company? @relation(fields: [companyId], references: [id])
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Authority {
  id        String   @id @default(cuid())
  name      String
  contact   String?
  area      String?
  status    String   @default("Activa")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Expiration {
  id          String    @id @default(cuid())
  code        String
  concept     String
  responsible String?
  dueDate     DateTime?
  status      String    @default("Pendiente")
  companyId   String?
  company     Company?  @relation(fields: [companyId], references: [id])
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model AuditTrail {
  id          String   @id @default(cuid())
  module      String
  action      String
  recordId    String?
  recordLabel String?
  responsible String?
  status      String?
  snapshot    String?
  createdAt   DateTime @default(now())
}

model SopDocument {
  id            String                @id @default(cuid())
  code          String
  title         String
  area          String?
  version       String                @default("1.0")
  status        String                @default("Borrador")
  owner         String?
  effectiveDate DateTime?
  records       ControlledRecord[]
  signatures    ElectronicSignature[]
  createdAt     DateTime              @default(now())
  updatedAt     DateTime              @updatedAt
}

model ControlledRecord {
  id         String                @id @default(cuid())
  code       String
  title      String
  type       String?
  status     String                @default("Borrador")
  sopId      String?
  sop        SopDocument?          @relation(fields: [sopId], references: [id])
  signatures ElectronicSignature[]
  createdAt  DateTime              @default(now())
  updatedAt  DateTime              @updatedAt
}

model ElectronicSignature {
  id        String            @id @default(cuid())
  signer    String
  role      String?
  action    String
  status    String            @default("Firmado")
  signedAt  DateTime          @default(now())
  sopId     String?
  sop       SopDocument?      @relation(fields: [sopId], references: [id])
  recordId  String?
  record    ControlledRecord? @relation(fields: [recordId], references: [id])
  evidence  String?
  createdAt DateTime          @default(now())
}

model Supplier {
  id        String   @id @default(cuid())
  name      String
  nit       String?
  category  String?
  contact   String?
  status    String   @default("Aprobado")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PurchaseOrder {
  id        String   @id @default(cuid())
  code      String
  supplier  String?
  item      String
  quantity  Float?
  status    String   @default("Solicitada")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReceptionRecord {
  id        String   @id @default(cuid())
  code      String
  supplier  String?
  item      String
  lot       String?
  quantity  Float?
  status    String   @default("Cuarentena")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model QuarantineItem {
  id        String   @id @default(cuid())
  code      String
  itemType  String?
  lot       String?
  reason    String?
  status    String   @default("Pendiente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model ReleaseRecord {
  id         String   @id @default(cuid())
  code       String
  itemType   String?
  lot        String?
  approvedBy String?
  status     String   @default("Aprobado")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model RawMaterial {
  id        String   @id @default(cuid())
  code      String
  name      String
  supplier  String?
  lot       String?
  stock     Float?
  status    String   @default("Cuarentena")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model InputItem {
  id        String   @id @default(cuid())
  code      String
  name      String
  category  String?
  stock     Float?
  status    String   @default("Disponible")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Product {
  id           String   @id @default(cuid())
  code         String
  name         String
  lot          String?
  presentation String?
  stock        Float?
  status       String   @default("Cuarentena")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Equipment {
  id                 String              @id @default(cuid())
  code               String
  name               String
  area               String?
  status             String              @default("Activo")
  calibrationRecords CalibrationRecord[]
  maintenanceRecords MaintenanceRecord[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt
}

model CalibrationRecord {
  id            String     @id @default(cuid())
  code          String
  equipmentName String?
  dueDate       DateTime?
  status        String     @default("Pendiente")
  equipmentId   String?
  equipment     Equipment? @relation(fields: [equipmentId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model MaintenanceRecord {
  id            String     @id @default(cuid())
  code          String
  equipmentName String?
  type          String?
  dueDate       DateTime?
  status        String     @default("Pendiente")
  equipmentId   String?
  equipment     Equipment? @relation(fields: [equipmentId], references: [id])
  createdAt     DateTime   @default(now())
  updatedAt     DateTime   @updatedAt
}

model CleaningRecord {
  id          String   @id @default(cuid())
  code        String
  area        String?
  procedure   String?
  responsible String?
  status      String   @default("Pendiente")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model BiosafetyRecord {
  id          String   @id @default(cuid())
  code        String
  area        String?
  eventType   String?
  responsible String?
  status      String   @default("Pendiente")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model WasteRecord {
  id        String   @id @default(cuid())
  code      String
  type      String?
  quantity  Float?
  status    String   @default("Pendiente")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EnvironmentalRecord {
  id        String   @id @default(cuid())
  code      String
  variable  String?
  value     String?
  unit      String?
  status    String   @default("Cumple")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model TrainingRecord {
  id          String    @id @default(cuid())
  code        String
  topic       String?
  participant String?
  dueDate     DateTime?
  status      String    @default("Pendiente")
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model Deviation {
  id          String    @id @default(cuid())
  code        String
  area        String?
  description String?
  severity    String    @default("Media")
  responsible String?
  status      String    @default("Abierta")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model NonConformity {
  id          String    @id @default(cuid())
  code        String
  source      String?
  description String?
  severity    String    @default("Media")
  responsible String?
  status      String    @default("Abierta")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model CapaAction {
  id               String    @id @default(cuid())
  code             String
  origin           String?
  rootCause        String?
  correctiveAction String?
  preventiveAction String?
  responsible      String?
  status           String    @default("Abierta")
  dueDate          DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt
}

model RiskAssessment {
  id          String   @id @default(cuid())
  code        String
  process     String?
  risk        String?
  probability String?
  impact      String?
  level       String   @default("Medio")
  control     String?
  status      String   @default("Abierto")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ChangeControl {
  id          String    @id @default(cuid())
  code        String
  area        String?
  changeType  String?
  description String?
  impact      String?
  responsible String?
  status      String    @default("Solicitado")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model QualityAudit {
  id        String    @id @default(cuid())
  code      String
  auditType String?
  area      String?
  auditor   String?
  finding   String?
  status    String    @default("Programada")
  dueDate   DateTime?
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model SecurityRole {
  id          String   @id @default(cuid())
  code        String   @unique
  name        String
  level       String   @default("Operativo")
  description String?
  status      String   @default("Activo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SecurityPermission {
  id          String   @id @default(cuid())
  code        String
  module      String
  action      String
  roleCode    String?
  description String?
  status      String   @default("Activo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model AccessLog {
  id        String   @id @default(cuid())
  userEmail String?
  event     String
  module    String?
  status    String   @default("Registrado")
  ip        String?
  createdAt DateTime @default(now())
}

model SystemSetting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String?
  category  String?
  status    String   @default("Activo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model MasterData {
  id        String   @id @default(cuid())
  code      String
  category  String
  name      String
  value     String?
  status    String   @default("Activo")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model BackupRecord {
  id        String   @id @default(cuid())
  code      String
  type      String   @default("Manual")
  fileName  String?
  status    String   @default("Creado")
  createdBy String?
  createdAt DateTime @default(now())
}

model ValidationProtocol {
  id          String    @id @default(cuid())
  code        String
  type        String    @default("IQ")
  scope       String?
  responsible String?
  status      String    @default("Borrador")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model ValidationTest {
  id             String   @id @default(cuid())
  code           String
  protocolCode   String?
  requirement    String?
  expectedResult String?
  actualResult   String?
  status         String   @default("Pendiente")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model ElectronicRecordControl {
  id         String   @id @default(cuid())
  code       String
  regulation String   @default("21 CFR Part 11")
  control    String?
  evidence   String?
  status     String   @default("Pendiente")
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AiRecommendation {
  id             String   @id @default(cuid())
  engine         String
  module         String?
  category       String?
  title          String
  finding        String?
  recommendation String?
  severity       String   @default("Media")
  status         String   @default("Abierta")
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model WorkflowProcess {
  id          String   @id @default(cuid())
  code        String
  name        String
  module      String?
  description String?
  status      String   @default("Activo")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model ApprovalRequest {
  id          String    @id @default(cuid())
  code        String
  module      String
  recordLabel String?
  requestedBy String?
  approver    String?
  action      String?
  status      String    @default("Pendiente")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model TaskItem {
  id          String    @id @default(cuid())
  code        String
  title       String
  module      String?
  responsible String?
  priority    String    @default("Media")
  status      String    @default("Pendiente")
  dueDate     DateTime?
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
}

model SystemNotification {
  id        String   @id @default(cuid())
  code      String
  title     String
  message   String?
  module    String?
  severity  String   @default("Media")
  status    String   @default("No leída")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model EvidenceRecord {
  id              String   @id @default(cuid())
  code            String
  standard        String?
  module          String?
  requirementCode String?
  evidenceType    String?
  title           String
  location        String?
  owner           String?
  status          String   @default("Pendiente")
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt
}

model AuditPackage {
  id         String    @id @default(cuid())
  code       String
  name       String
  standard   String?
  auditor    String?
  status     String    @default("En preparación")
