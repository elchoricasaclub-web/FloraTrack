  const labels: Record<string, string> = {
    code: "Código",
    sourceHarvestCode: "Cosecha origen",
    geneticCode: "Genética",
    biomassType: "Tipo biomasa",
    weightReceived: "Peso recibido",
    temperatureAtReceipt: "Temperatura recepción",
    coldChainStatus: "Estado cadena frío",
    qcStatus: "Estado QC",
    storageLocation: "Ubicación almacenamiento",
    responsible: "Responsable",
    status: "Estado",
    biomassBatchCode: "Lote biomasa",
    checkpoint: "Punto control",
    temperatureStatus: "Estado temperatura",
    recordedAt: "Fecha/hora registro",
    location: "Ubicación",
    deviationFound: "Desviación encontrada",
    washRunType: "Tipo lavado",
    equipmentCode: "Equipo",
    waterQuality: "Calidad agua",
    iceLot: "Lote hielo",
    operatorName: "Operador",
    inputWeight: "Peso entrada",
    outputWetHash: "Salida hash húmedo",
    processStatus: "Estado proceso",
    washBatchCode: "Lote lavado",
    micronRange: "Rango micras",
    wetWeight: "Peso húmedo",
    dryWeight: "Peso seco",
    disposition: "Disposición",
    fractionCode: "Fracción",
    cycleCode: "Ciclo",
    moistureStatus: "Estado humedad",
    startDate: "Fecha inicio",
    endDate: "Fecha fin",
    freezeDryBatchCode: "Lote liofilización",
    productType: "Tipo producto",
    weight: "Peso",
    storageCondition: "Condición almacenamiento",
    intermediateCode: "Producto intermedio",
    pressEquipmentCode: "Equipo prensa",
    pressRunCode: "Código corrida",
    temperatureRecord: "Registro temperatura",
    pressureRecord: "Registro presión",
    timeRecord: "Registro tiempo",
    outputWeight: "Peso salida",
    yieldPercent: "Rendimiento %",
    pressBatchCode: "Lote prensado",
