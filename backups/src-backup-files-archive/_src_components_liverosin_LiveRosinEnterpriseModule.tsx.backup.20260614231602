"use client";

import { useEffect, useMemo, useState } from "react";

type TabConfig = {
  model: string;
  title: string;
  description: string;
  fields: string[];
};

const tabs: TabConfig[] = [
  {
    model: "biomass",
    title: "Biomasa",
    description: "Recepción regulatoria de biomasa: genética, cosecha, peso, cadena de frío, cuarentena y ubicación.",
    fields: ["code", "sourceHarvestCode", "geneticCode", "biomassType", "weightReceived", "temperatureAtReceipt", "coldChainStatus", "qcStatus", "storageLocation", "responsible", "status"],
  },
  {
    model: "cold-chain",
    title: "Cadena de frío",
    description: "Control documental de temperatura, puntos de transferencia, ubicación, desviaciones y responsable.",
    fields: ["code", "biomassBatchCode", "checkpoint", "temperatureStatus", "recordedAt", "location", "deviationFound", "responsible", "status"],
  },
  {
    model: "wash",
    title: "Bubble Hash",
    description: "Batch record de lavado solventless autorizado: equipo, agua, hielo, operador, entrada y salida.",
    fields: ["code", "biomassBatchCode", "washRunType", "equipmentCode", "waterQuality", "iceLot", "operatorName", "inputWeight", "outputWetHash", "processStatus", "status"],
  },
  {
    model: "fractions",
    title: "Fracciones micras",
    description: "Fracciones por rango de micras, peso húmedo/seco, cuarentena, disposición y QC.",
    fields: ["code", "washBatchCode", "micronRange", "wetWeight", "dryWeight", "qcStatus", "disposition", "status"],
  },
  {
    model: "freeze-dry",
    title: "Liofilización",
    description: "Control del ciclo de liofilización, equipo, humedad, operador, estado QC y liberación intermedia.",
    fields: ["code", "fractionCode", "equipmentCode", "cycleCode", "moistureStatus", "startDate", "endDate", "operatorName", "qcStatus", "status"],
  },
  {
    model: "intermediate",
    title: "Producto intermedio",
    description: "Producto intermedio seco, peso, almacenamiento, cuarentena y estado de calidad.",
    fields: ["code", "freezeDryBatchCode", "productType", "weight", "qcStatus", "storageCondition", "status"],
  },
  {
    model: "press",
    title: "Prensado",
    description: "Registro regulatorio de prensado: equipo, temperatura, presión, tiempo, entrada, salida, rendimiento y QC.",
    fields: ["code", "intermediateCode", "pressEquipmentCode", "pressRunCode", "temperatureRecord", "pressureRecord", "timeRecord", "inputWeight", "outputWeight", "yieldPercent", "operatorName", "qcStatus", "status"],
  },
  {
    model: "finished",
    title: "Producto terminado",
    description: "Lote terminado, producto, empaque, almacenamiento, muestra, COA, decisión QA y estado.",
    fields: ["code", "pressBatchCode", "productName", "batchSize", "packagingType", "storageCondition", "sampleCode", "coaCode", "releaseDecision", "qaResponsible", "status"],
  },
  {
    model: "yield",
    title: "Rendimientos",
    description: "Revisión de rendimientos por etapa para tendencia, desviación y mejora continua.",
    fields: ["code", "sourceBatchCode", "stage", "inputWeight", "outputWeight", "yieldPercent", "trendConclusion", "reviewedBy", "status"],
  },
  {
    model: "release",
    title: "Liberación QA",
    description: "Disposición final del lote, COA, decisión, responsable, fecha y notas de liberación.",
    fields: ["code", "finishedBatchCode", "coaCode", "disposition", "releaseDecision", "releasedBy", "releaseDate", "notes", "status"],
  },
];

function emptyForm(fields: string[]) {
  return fields.reduce((acc: Record<string, string>, field) => {
    acc[field] = "";
    return acc;
  }, {});
}

