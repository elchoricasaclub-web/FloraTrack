import { NextResponse } from "next/server";
import fs from "fs";
import path from "path";

export const runtime = "nodejs";
export const dynamic = "force-dynamic";

const dataDir = path.join(process.cwd(), "data");
const dataFile = path.join(dataDir, "progress-records.json");

function ensureStore() {
  if (!fs.existsSync(dataDir)) fs.mkdirSync(dataDir, { recursive: true });
  if (!fs.existsSync(dataFile)) fs.writeFileSync(dataFile, "[]", "utf8");
}

function readRecords() {
  ensureStore();

  try {
    return JSON.parse(fs.readFileSync(dataFile, "utf8"));
  } catch {
    return [];
  }
}

function writeRecords(records: any[]) {
  ensureStore();
  fs.writeFileSync(dataFile, JSON.stringify(records, null, 2), "utf8");
}

export async function GET() {
  const records = readRecords();

  return NextResponse.json({
    ok: true,
    total: records.length,
    records: records.slice().reverse(),
  });
}

export async function POST(request: Request) {
  const contentType = request.headers.get("content-type") ?? "";
  let body: Record<string, string> = {};

  if (contentType.includes("application/json")) {
    try {
      body = await request.json();
    } catch {
      body = {};
    }
  } else {
    const formData = await request.formData();
    for (const [key, value] of formData.entries()) body[key] = String(value);
  }

  const records = readRecords();

  const record = {
    id: `PROG-${Date.now()}`,
    createdAt: new Date().toISOString(),
    moduleName: body.moduleName || "FloraTrack",
    itemTitle: body.itemTitle || body.buttonText || "Guardar avance",
    actionType: body.actionType || "save-progress",
    owner: body.owner || "Usuario actual",
    status: body.status || "Guardado",
    evidence: body.evidence || "Evidencia registrada automáticamente",
    note: body.note || "Avance guardado correctamente.",
  };

  records.push(record);
  writeRecords(records);

  if (!contentType.includes("application/json")) {
    return NextResponse.redirect(new URL("/progress-records", request.url), { status: 303 });
  }

  return NextResponse.json({
    ok: true,
    record,
  });
}
