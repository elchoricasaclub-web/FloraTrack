"use client";

import { useEffect, useState } from "react";

type ToastType = "error" | "warning" | "success";

type ToastState = {
  show: boolean;
  type: ToastType;
  title: string;
  message: string;
  fields: string[];
};

const ignoredFieldNames = [
  "id",
  "createdAt",
  "updatedAt",
  "pageUrl",
  "sourceButton",
  "actionType",
  "status",
];

function normalize(value: string) {
  return value.replace(/\s+/g, " ").trim();
}

function getLabel(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  const name = field.getAttribute("name") || "";
  const placeholder = field.getAttribute("placeholder") || "";
  const aria = field.getAttribute("aria-label") || "";

  const labelElement = field.closest("div")?.querySelector("label");
  const labelText = labelElement?.textContent || "";

  return normalize(labelText || placeholder || aria || name || "Campo requerido");
}

function isHiddenField(field: Element) {
  if (!(field instanceof HTMLInputElement)) return false;
  return field.type === "hidden";
}

function isIgnoredField(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  const name = field.getAttribute("name") || "";

  if (!name) return true;
  if (ignoredFieldNames.includes(name)) return true;
  if (isHiddenField(field)) return true;
  if (field.disabled) return true;

  return false;
}

function isEmptyValue(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  const value = normalize(field.value || "");

  if (field instanceof HTMLSelectElement) {
    return value === "" || value === "Seleccione" || value === "Seleccionar";
  }

  return value.length === 0;
}

function isFormThatSaves(form: HTMLFormElement) {
  const action = String(form.getAttribute("action") || "").toLowerCase();

  if (action.includes("/api/")) return true;
  if (action.includes("records")) return true;
  if (action.includes("cultivos")) return true;
  if (action.includes("propagacion")) return true;
  if (action.includes("cosecha")) return true;

  const buttonText = Array.from(form.querySelectorAll("button"))
    .map((button) => button.textContent || "")
    .join(" ")
    .toLowerCase();

  return (
    buttonText.includes("guardar") ||
    buttonText.includes("crear") ||
    buttonText.includes("registrar") ||
    buttonText.includes("enviar")
  );
}

function clearMarks(form: HTMLFormElement) {
  const fields = form.querySelectorAll("input, textarea, select");

  fields.forEach((field) => {
    field.classList.remove("border-red-500", "ring-4", "ring-red-100", "bg-red-50");
  });
}

function markField(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  field.classList.add("border-red-500", "ring-4", "ring-red-100", "bg-red-50");
}

export default function GlobalFormValidator() {
  const [toast, setToast] = useState<ToastState>({
    show: false,
    type: "error",
    title: "",
    message: "",
    fields: [],
  });

  useEffect(() => {
    function showToast(fields: string[]) {
      setToast({
        show: true,
        type: "error",
        title: "Falta información requerida",
        message: "No se puede guardar el registro hasta completar los campos obligatorios.",
        fields,
      });

      window.setTimeout(() => {
        setToast((current) => ({
          ...current,
          show: false,
        }));
      }, 7000);
    }

    function handleSubmit(event: SubmitEvent) {
      const form = event.target as HTMLFormElement | null;

      if (!form) return;
      if (!(form instanceof HTMLFormElement)) return;
      if (!isFormThatSaves(form)) return;

      clearMarks(form);

      const fields = Array.from(form.querySelectorAll("input, textarea, select")) as Array<
        HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
      >;

      const missingFields: string[] = [];

      fields.forEach((field) => {
        if (isIgnoredField(field)) return;

        if (isEmptyValue(field)) {
          markField(field);
          missingFields.push(getLabel(field));
        }
      });

      const uniqueMissingFields = Array.from(new Set(missingFields));

      if (uniqueMissingFields.length > 0) {
        event.preventDefault();
        event.stopPropagation();

        showToast(uniqueMissingFields);

        const firstInvalid = fields.find((field) => {
          if (isIgnoredField(field)) return false;
          return isEmptyValue(field);
        });

        firstInvalid?.focus();

        return false;
      }
    }

    document.addEventListener("submit", handleSubmit, true);

    return () => {
      document.removeEventListener("submit", handleSubmit, true);
    };
  }, []);

  if (!toast.show) return null;

  return (
    <div className="fixed right-6 top-24 z-[100000] w-[420px] rounded-3xl border border-red-200 bg-white p-6 shadow-2xl">
      <div className="flex items-start gap-4">
        <div className="flex h-12 w-12 items-center justify-center rounded-2xl bg-red-100 text-2xl">
          ⚠️
        </div>

        <div className="flex-1">
          <div className="text-xs font-black uppercase tracking-widest text-red-600">
            Validación de registro
          </div>

          <h3 className="mt-1 text-2xl font-black text-slate-900">
            {toast.title}
          </h3>

          <p className="mt-2 text-sm font-semibold text-slate-600">
            {toast.message}
          </p>

          <div className="mt-4 rounded-2xl bg-red-50 p-4">
            <div className="text-xs font-black uppercase tracking-widest text-red-500">
              Completa estos campos:
            </div>

            <ul className="mt-2 space-y-1 text-sm font-bold text-red-700">
              {toast.fields.slice(0, 8).map((field) => (
                <li key={field}>• {field}</li>
              ))}
            </ul>

            {toast.fields.length > 8 && (
              <div className="mt-2 text-sm font-bold text-red-700">
                • Y otros campos requeridos...
              </div>
            )}
          </div>

          <button
            type="button"
            onClick={() =>
              setToast((current) => ({
                ...current,
                show: false,
              }))
            }
            className="mt-4 rounded-2xl bg-red-600 px-5 py-3 text-sm font-black text-white hover:bg-red-700"
          >
            Entendido
          </button>
        </div>
      </div>
    </div>
  );
}
