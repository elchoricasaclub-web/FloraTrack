  const labels: Record<string, string> = {
    code: "Código",
    systemName: "Sistema",
    systemVersion: "Versión",
    validationScope: "Alcance validación",
    validationApproach: "Enfoque",
    riskBasedRationale: "Justificación basada en riesgo",
    ownerRole: "Rol dueño",
    approvalStatus: "Aprobación",
    status: "Estado",
    moduleName: "Módulo",
    gxpImpact: "Impacto GxP",
    dataCriticality: "Criticidad datos",
    supplier: "Proveedor",
    hostingModel: "Hosting",
    validationCategory: "Categoría validación",
    requirementTitle: "Título requisito",
    requirementText: "Requisito",
    businessProcess: "Proceso",
    regulatoryReference: "Referencia regulatoria",
    priority: "Prioridad",
    acceptanceCriteria: "Criterios aceptación",
    ursCode: "Código URS",
    functionName: "Función",
    functionDescription: "Descripción función",
    technicalControl: "Control técnico",
    testable: "Testeable",
    processName: "Proceso",
    failureMode: "Modo de falla",
    impact: "Impacto",
    probability: "Probabilidad",
    detectability: "Detectabilidad",
    riskPriority: "Prioridad riesgo",
    mitigation: "Mitigación",
    residualRisk: "Riesgo residual",
    frsCode: "Código FRS",
    riskCode: "Código riesgo",
    testScriptCode: "Script prueba",
    evidenceRef: "Evidencia",
    traceStatus: "Estado trazabilidad",
    testType: "Tipo prueba",
    testTitle: "Título prueba",
    objective: "Objetivo",
    preconditions: "Precondiciones",
    steps: "Pasos",
    expectedResult: "Resultado esperado",
    executedBy: "Ejecutado por",
    executionDate: "Fecha ejecución",
    actualResult: "Resultado real",
    passFail: "Pass/Fail",
    evidence: "Evidencia",
    reviewer: "Revisor",
    testExecutionCode: "Ejecución",
    deviationTitle: "Título desviación",
    severity: "Severidad",
    rootCause: "Causa raíz",
    correctiveAction: "Acción correctiva",
    impactAssessment: "Evaluación impacto",
    closureStatus: "Cierre",
