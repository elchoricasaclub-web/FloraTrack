"use client";

import { useEffect, useMemo, useState } from "react";

type TabConfig = {
  model: string;
  title: string;
  description: string;
  fields: string[];
};

const tabs: TabConfig[] = [
  {
    model: "master-plan",
    title: "Plan maestro",
    description: "VMP CSV: alcance, versión, enfoque, justificación basada en riesgo y aprobación.",
    fields: ["code", "systemName", "systemVersion", "validationScope", "validationApproach", "riskBasedRationale", "ownerRole", "approvalStatus", "status"],
  },
  {
    model: "inventory",
    title: "Inventario sistema",
    description: "Inventario de módulos y sistemas con impacto GxP, criticidad de datos y categoría de validación.",
    fields: ["code", "systemName", "moduleName", "gxpImpact", "dataCriticality", "supplier", "hostingModel", "validationCategory", "status"],
  },
  {
    model: "urs",
    title: "URS",
    description: "Requisitos de usuario con proceso, referencia regulatoria, prioridad y criterios de aceptación.",
    fields: ["code", "requirementTitle", "requirementText", "businessProcess", "regulatoryReference", "priority", "acceptanceCriteria", "approvalStatus", "status"],
  },
  {
    model: "frs",
    title: "FRS",
    description: "Requisitos funcionales derivados de URS con control técnico y testabilidad.",
    fields: ["code", "ursCode", "functionName", "functionDescription", "moduleName", "technicalControl", "testable", "status"],
  },
  {
    model: "risk",
    title: "Riesgos",
    description: "Evaluación de riesgo CSV por proceso, falla, impacto, probabilidad, mitigación y riesgo residual.",
    fields: ["code", "processName", "failureMode", "impact", "probability", "detectability", "riskPriority", "mitigation", "residualRisk", "status"],
  },
  {
    model: "traceability",
    title: "Matriz trazabilidad",
    description: "Relación URS → FRS → Riesgo → Prueba → Evidencia.",
    fields: ["code", "ursCode", "frsCode", "riskCode", "testScriptCode", "evidenceRef", "traceStatus", "status"],
  },
  {
    model: "scripts",
    title: "Scripts IQ/OQ/PQ",
    description: "Scripts de prueba con objetivo, precondiciones, pasos y resultado esperado.",
    fields: ["code", "testType", "testTitle", "moduleName", "objective", "preconditions", "steps", "expectedResult", "approvalStatus", "status"],
  },
  {
    model: "execution",
    title: "Ejecución pruebas",
    description: "Ejecución de pruebas, resultado real, pass/fail, evidencia y revisor.",
    fields: ["code", "testScriptCode", "executedBy", "executionDate", "actualResult", "passFail", "evidence", "reviewer", "status"],
  },
  {
    model: "deviations",
    title: "Desviaciones",
    description: "Desviaciones de validación, severidad, causa raíz, acción correctiva, impacto y cierre.",
    fields: ["code", "testExecutionCode", "deviationTitle", "severity", "rootCause", "correctiveAction", "impactAssessment", "closureStatus", "status"],
  },
  {
    model: "reports",
    title: "Reporte final",
    description: "Reporte final de validación, resumen, desviaciones, conclusión y aprobación.",
    fields: ["code", "reportTitle", "systemName", "summary", "deviationsSummary", "finalConclusion", "approvedBy", "approvalDate", "reportStatus", "status"],
  },
  {
    model: "periodic-review",
    title: "Revisión periódica",
    description: "Revisión periódica de estado validado: cambios, incidentes, audit trail y conclusión.",
    fields: ["code", "systemName", "reviewPeriod", "reviewer", "changeSummary", "incidentsSummary", "auditTrailSummary", "continuedValidation", "reviewStatus", "status"],
  },
];

function emptyForm(fields: string[]) {
  return fields.reduce((acc: Record<string, string>, field) => {
    acc[field] = "";
    return acc;
  }, {});
}

