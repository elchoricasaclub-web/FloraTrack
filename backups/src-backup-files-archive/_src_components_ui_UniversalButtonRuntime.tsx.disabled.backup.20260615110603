"use client";

import { useEffect, useState } from "react";

type RuntimeAction = {
  moduleName: string;
  buttonText: string;
  actionType: string;
  pageUrl: string;
  createdAt: string;
};

function cleanText(value: string) {
  return value.replace(/\s+/g, " ").trim().slice(0, 90);
}

function getModuleName() {
  const headerElement = document.querySelector("header h1");
  const mainTitleElement = document.querySelector("main h1");
  const sectionTitleElement = document.querySelector("main h2, section h2");

  const headerText = headerElement?.textContent?.trim();
  const mainTitleText = mainTitleElement?.textContent?.trim();
  const sectionTitleText = sectionTitleElement?.textContent?.trim();

  return headerText || mainTitleText || sectionTitleText || "FloraTrack";
}

function getActionType(buttonText: string) {
  const value = buttonText.toLowerCase();

  if (value.includes("guardar")) return "save-progress";
  if (value.includes("evidencia")) return "evidence";
  if (value.includes("audit")) return "audit-trail";
  if (value.includes("capa")) return "capa";
  if (value.includes("export")) return "export";
  if (value.includes("nuevo") || value.includes("nueva")) return "create";
  if (value.includes("abrir") || value.includes("ver")) return "open";
  if (value.includes("actualizar")) return "refresh";

  return "button-click";
}

function shouldSkipButton(button: HTMLButtonElement) {
  if (button.closest("[data-global-save-form='true']")) return true;
  if (button.closest("[data-button-runtime='true']")) return true;
  if (button.type === "submit") return true;
  return false;
}

export default function UniversalButtonRuntime() {
  const [drawer, setDrawer] = useState<RuntimeAction | null>(null);
  const [toast, setToast] = useState("");

  useEffect(() => {
    async function handleClick(event: MouseEvent) {
      const target = event.target as HTMLElement | null;
      const button = target?.closest("button") as HTMLButtonElement | null;

      if (!button) return;
      if (button.disabled) return;
      if (shouldSkipButton(button)) return;

      const buttonText = cleanText(button.textContent || button.getAttribute("aria-label") || "Botón");
      if (!buttonText) return;

      const moduleName = getModuleName();
      const actionType = getActionType(buttonText);

      const payload = {
        moduleName,
        buttonText,
        itemTitle: buttonText,
        actionType,
        pageUrl: window.location.pathname,
        status: "Registrado",
        owner: "Usuario actual",
        evidence: "Acción ejecutada desde " + moduleName,
        note: "Botón activado: " + buttonText,
        result: "Panel abierto y acción registrada correctamente",
      };

      try {
        await fetch("/api/button-actions", {
          method: "POST",
          headers: {
            "Content-Type": "application/json",
          },
          body: JSON.stringify(payload),
        });

        if (actionType === "save-progress") {
          await fetch("/api/progress-records", {
            method: "POST",
            headers: {
              "Content-Type": "application/json",
            },
            body: JSON.stringify({
              ...payload,
              status: "Guardado",
              note: "Avance guardado desde botón: " + buttonText,
            }),
          });
        }

        setDrawer({
          moduleName,
          buttonText,
          actionType,
          pageUrl: window.location.pathname,
          createdAt: new Date().toISOString(),
        });

        setToast(actionType === "save-progress" ? "Avance guardado" : "Botón activado");
        window.setTimeout(() => setToast(""), 3000);
      } catch {
        setToast("No se pudo registrar el botón");
        window.setTimeout(() => setToast(""), 3000);
      }
    }

    document.addEventListener("click", handleClick);

    return () => {
      document.removeEventListener("click", handleClick);
    };
  }, []);

  return (
    <div data-button-runtime="true">
      <form
        data-global-save-form="true"
        action="/api/progress-records"
        method="post"
        className="fixed bottom-6 right-6 z-[99999] rounded-3xl border border-green-200 bg-white p-4 shadow-2xl"
      >
        <input type="hidden" name="moduleName" value="FloraTrack Global" />
        <input type="hidden" name="itemTitle" value="Guardar avance actual" />
        <input type="hidden" name="actionType" value="safe-global-save" />
        <input type="hidden" name="owner" value="Usuario actual" />
        <input type="hidden" name="status" value="Guardado" />
        <input type="hidden" name="evidence" value="Guardado global seguro" />
        <input type="hidden" name="note" value="Avance guardado desde botón flotante global." />

        <div className="text-xs font-black uppercase tracking-widest text-green-600">
          Guardado seguro
        </div>

        <button
          type="submit"
          className="mt-2 rounded-2xl bg-green-600 px-5 py-3 text-sm font-black text-white hover:bg-green-700"
        >
          Guardar avance actual
        </button>

        <div className="mt-3 flex gap-2">
          <a
            href="/progress-records"
            className="rounded-xl border px-3 py-2 text-xs font-black text-slate-700"
          >
            Registros
          </a>

          <a
            href="/action-center"
            className="rounded-xl border px-3 py-2 text-xs font-black text-slate-700"
          >
            Acciones
          </a>
        </div>
      </form>

      {toast && (
        <div className="fixed bottom-40 right-6 z-[99999] rounded-2xl bg-slate-950 px-6 py-4 font-black text-white shadow-2xl">
          {toast}
        </div>
      )}

      {drawer && (
        <div className="fixed inset-0 z-[99998] flex justify-end bg-slate-950/40">
          <aside className="h-full w-full max-w-2xl overflow-y-auto bg-white p-8 shadow-2xl">
            <div className="flex items-start justify-between gap-5">
              <div>
                <div className="text-xs font-black uppercase tracking-widest text-green-600">
                  {drawer.moduleName} · Botón activo
                </div>

                <h2 className="mt-2 text-4xl font-black text-slate-900">
                  {drawer.buttonText}
                </h2>

                <p className="mt-3 text-slate-500">
                  Esta acción fue capturada y registrada por el activador universal de botones.
                </p>
              </div>

              <button
                type="button"
                onClick={() => setDrawer(null)}
                className="rounded-2xl border px-4 py-3 font-black text-slate-700"
              >
                Cerrar
              </button>
            </div>

            <div className="mt-8 grid grid-cols-2 gap-4">
              <div className="rounded-2xl border bg-slate-50 p-5">
                <div className="text-xs font-bold text-slate-400">Tipo de acción</div>
                <div className="mt-1 text-xl font-black text-slate-900">
                  {drawer.actionType}
                </div>
              </div>

              <div className="rounded-2xl border bg-slate-50 p-5">
                <div className="text-xs font-bold text-slate-400">Ruta</div>
                <div className="mt-1 text-xl font-black text-slate-900">
                  {drawer.pageUrl}
                </div>
              </div>

              <div className="rounded-2xl border bg-slate-50 p-5">
                <div className="text-xs font-bold text-slate-400">Estado</div>
                <div className="mt-1 text-xl font-black text-green-700">
                  Registrado
                </div>
              </div>

              <div className="rounded-2xl border bg-slate-50 p-5">
                <div className="text-xs font-bold text-slate-400">Fecha</div>
                <div className="mt-1 text-xl font-black text-slate-900">
                  {new Date(drawer.createdAt).toLocaleString()}
                </div>
              </div>
            </div>

            <div className="mt-8 flex flex-wrap gap-3">
              <a
                href="/action-center"
                className="rounded-2xl bg-green-600 px-5 py-4 font-black text-white"
              >
                Ver Action Center
              </a>

              <a
                href="/progress-records"
                className="rounded-2xl border px-5 py-4 font-black text-slate-700"
              >
                Ver avances
              </a>
            </div>
          </aside>
        </div>
      )}
    </div>
  );
}
