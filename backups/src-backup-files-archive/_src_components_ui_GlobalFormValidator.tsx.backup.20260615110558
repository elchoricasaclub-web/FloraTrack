"use client";

import { useEffect, useState } from "react";

type ToastState = {
  show: boolean;
  title: string;
  message: string;
  fields: string[];
};

const genericValues = [
  "nuevo registro",
  "nuevo registro floratrack",
  "responsable gacp",
  "usuario actual",
  "registro creado desde nuevo registro",
  "registro creado desde nuevo registro.",
  "registro creado desde el botón nuevo registro del dashboard.",
  "registro creado desde el boton nuevo registro del dashboard.",
  "registro creado desde el módulo cultivos.",
  "registro creado desde el modulo cultivos.",
  "registro creado desde el módulo propagación.",
  "registro creado desde el modulo propagacion.",
  "registro creado desde el módulo cosecha.",
  "registro creado desde el modulo cosecha.",
  "evidencia pendiente",
  "sin genética asignada",
  "sin genetica asignada",
  "cultivo sin asignar"
];

const ignoredNames = [
  "id",
  "createdAt",
  "updatedAt",
  "moduleName",
  "sourceButton",
  "pageUrl",
  "actionType"
];

const numericMustBePositive = [
  "cantidad",
  "pesoEstimadoKg"
];

function normalize(value: string) {
  return value.replace(/\s+/g, " ").trim();
}

function normalizedLower(value: string) {
  return normalize(value).toLowerCase();
}

function getFieldLabel(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  const label = field.closest("div")?.querySelector("label")?.textContent || "";
  const placeholder = field.getAttribute("placeholder") || "";
  const name = field.getAttribute("name") || "";

  return normalize(label || placeholder || name || "Campo requerido");
}

function shouldIgnoreField(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  const name = field.getAttribute("name") || "";

  if (!name) return true;
  if (ignoredNames.includes(name)) return true;
  if (field.disabled) return true;

  if (field instanceof HTMLInputElement && field.type === "hidden") return true;

  return false;
}

function isBadValue(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  const name = field.getAttribute("name") || "";
  const value = normalize(field.value || "");
  const lower = normalizedLower(value);

  if (!value) return true;
  if (genericValues.includes(lower)) return true;

  if (numericMustBePositive.includes(name)) {
    const numberValue = Number(value);

    if (Number.isNaN(numberValue) || numberValue <= 0) return true;
  }

  return false;
}

function isSaveForm(form: HTMLFormElement) {
  const action = String(form.getAttribute("action") || "").toLowerCase();

  if (action.includes("/api/")) return true;

  const text = Array.from(form.querySelectorAll("button"))
    .map((button) => button.textContent || "")
    .join(" ")
    .toLowerCase();

  return (
    text.includes("guardar") ||
    text.includes("crear") ||
    text.includes("registrar") ||
    text.includes("enviar")
  );
}

function clearMarks(form: HTMLFormElement) {
  form.querySelectorAll("input, textarea, select").forEach((field) => {
    field.classList.remove("border-red-500", "ring-4", "ring-red-100", "bg-red-50");
  });
}

function markField(field: HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement) {
  field.classList.add("border-red-500", "ring-4", "ring-red-100", "bg-red-50");
}

export default function GlobalFormValidator() {
  const [toast, setToast] = useState<ToastState>({
    show: false,
    title: "",
    message: "",
    fields: []
  });

  useEffect(() => {
    function showValidation(fields: string[]) {
      setToast({
        show: true,
        title: "Falta información requerida",
        message: "No se puede guardar. Completa la información obligatoria antes de registrar.",
        fields
      });

      window.setTimeout(() => {
        setToast((current) => ({
          ...current,
          show: false
        }));
      }, 8000);
    }

    function validateForm(form: HTMLFormElement) {
      clearMarks(form);

      const fields = Array.from(form.querySelectorAll("input, textarea, select")) as Array<
        HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement
      >;

      const missing: string[] = [];

      for (const field of fields) {
        if (shouldIgnoreField(field)) continue;

        if (isBadValue(field)) {
          markField(field);
          missing.push(getFieldLabel(field));
        }
      }

      return Array.from(new Set(missing));
    }

    function handleSubmit(event: SubmitEvent) {
      const form = event.target as HTMLFormElement | null;

      if (!form) return;
      if (!(form instanceof HTMLFormElement)) return;
      if (!isSaveForm(form)) return;

      const missing = validateForm(form);

      if (missing.length > 0) {
        event.preventDefault();
        event.stopPropagation();

        showValidation(missing);

        const firstInvalid = Array.from(form.querySelectorAll("input, textarea, select")).find((field) => {
          const typedField = field as HTMLInputElement | HTMLTextAreaElement | HTMLSelectElement;

          if (shouldIgnoreField(typedField)) return false;
          return isBadValue(typedField);
        }) as HTMLElement | undefined;

        firstInvalid?.focus();
      }
    }

    document.addEventListener("submit", handleSubmit, true);

    return () => {
      document.removeEventListener("submit", handleSubmit, true);
    };
  }, []);

  if (!toast.show) return null;

  return (
    <div className="fixed right-6 top-24 z-[100000] w-[440px] rounded-3xl border border-red-200 bg-white p-6 shadow-2xl">
      <div className="text-xs font-black uppercase tracking-widest text-red-600">
        Validación obligatoria
      </div>

      <h3 className="mt-2 text-2xl font-black text-slate-900">
        {toast.title}
      </h3>

      <p className="mt-2 text-sm font-semibold text-slate-600">
        {toast.message}
      </p>

      <div className="mt-4 rounded-2xl bg-red-50 p-4">
        <div className="text-xs font-black uppercase tracking-widest text-red-500">
          Debes llenar:
        </div>

        <ul className="mt-2 space-y-1 text-sm font-bold text-red-700">
          {toast.fields.slice(0, 8).map((field) => (
            <li key={field}>• {field}</li>
          ))}
        </ul>

        {toast.fields.length > 8 && (
          <div className="mt-2 text-sm font-bold text-red-700">
            • Y otros campos requeridos...
          </div>
        )}
      </div>

      <button
        type="button"
        onClick={() => setToast((current) => ({ ...current, show: false }))}
        className="mt-4 rounded-2xl bg-red-600 px-5 py-3 text-sm font-black text-white"
      >
        Entendido
      </button>
    </div>
  );
}
