"use client";

import { useEffect, useState } from "react";

type Issue = {
  severity: "Crítica" | "Alta" | "Media" | "Baja";
  area: string;
  message: string;
  recommendation: string;
};

type AppDoctorResponse = {
  ok: boolean;
  generatedAt: string;
  app: string;
  score: number;
  summary: Record<string, number>;
  versions: Record<string, string>;
  issues: Issue[];
  imports: Array<{
    name: string;
    importPath: string;
    file: string;
    ok: boolean;
  }>;
  menu: {
    items: string[];
    moduleMapKeys: string[];
    menuWithoutRoute: string[];
    routeWithoutMenu: string[];
  };
  files: {
    critical: Array<{ file: string; ok: boolean }>;
    dynamicApiRoutes: Array<{ routeFile: string; ok: boolean }>;
  };
  prisma: {
    schemaModels: string[];
    delegateChecks: Array<{
      delegate: string;
      ok: boolean;
      count: number;
      error?: string;
    }>;
  };
  recommendations: string[];
  error?: string;
};

function downloadJson(data: unknown) {
  const blob = new Blob([JSON.stringify(data, null, 2)], {
    type: "application/json",
  });

  const url = URL.createObjectURL(blob);
  const link = document.createElement("a");

  link.href = url;
  link.download = `floratrack_app_doctor_${new Date().toISOString().slice(0, 10)}.json`;
  link.click();

  URL.revokeObjectURL(url);
}

export default function AppDoctorModule() {
  const [data, setData] = useState<AppDoctorResponse | null>(null);
  const [message, setMessage] = useState("Ejecutando diagnóstico técnico...");
  const [tab, setTab] = useState("issues");

  async function loadData() {
    try {
      const response = await fetch("/api/enterprise/app-doctor", {
        cache: "no-store",
      });

      const result = await response.json();

      if (!result.ok) {
        setMessage(result.error || "Error ejecutando App Doctor.");
        return;
      }

      setData(result);
      setMessage("Diagnóstico técnico completado.");
    } catch {
      setMessage("No se pudo conectar App Doctor.");
    }
  }

  useEffect(() => {
    loadData();
  }, []);

  const tabs = [
    { id: "issues", label: "Problemas" },
    { id: "imports", label: "Imports" },
    { id: "menu", label: "Menú" },
    { id: "files", label: "APIs / Archivos" },
    { id: "prisma", label: "Prisma" },
  ];

  return (
    <section className="bg-white rounded-2xl shadow p-8">
      <div className="flex justify-between items-start gap-6 mb-8">
        <div>
          <h2 className="text-4xl font-bold text-slate-800">
            App Doctor Enterprise
          </h2>
          <p className="text-slate-500 mt-2 max-w-4xl leading-relaxed">
            Diagnóstico técnico interno de FloraTrack: imports, menú, rutas API,
            archivos críticos, Prisma Client, schema y sincronización general.
          </p>
        </div>

        <div className="flex gap-3">
          <button
            onClick={() => data && downloadJson(data)}
            className="bg-white border px-6 py-4 rounded-xl font-bold text-slate-700"
          >
            Exportar JSON
          </button>

          <button
            onClick={loadData}
            className="bg-green-600 hover:bg-green-700 text-white px-6 py-4 rounded-xl shadow text-lg font-bold"
          >
            Ejecutar
          </button>
        </div>
      </div>

      <div className="bg-green-50 border border-green-200 text-green-700 rounded-xl p-4 mb-8 font-semibold">
        {message}
      </div>

      {data && (
        <>
          <div className="grid grid-cols-6 gap-4 mb-8">
            <div className="border rounded-xl p-5">
              <div className="text-sm text-slate-500">Score técnico</div>
              <div className="text-5xl font-black text-green-600 mt-2">
                {data.score}%
              </div>
            </div>

            <div className="border rounded-xl p-5">
              <div className="text-sm text-slate-500">Problemas</div>
              <div className="text-5xl font-black text-red-600 mt-2">
                {data.summary.issues}
              </div>
            </div>

            <div className="border rounded-xl p-5">
              <div className="text-sm text-slate-500">Imports</div>
              <div className="text-5xl font-black text-slate-800 mt-2">
                {data.summary.imports}
              </div>
            </div>

            <div className="border rounded-xl p-5">
              <div className="text-sm text-slate-500">Menú</div>
              <div className="text-5xl font-black text-slate-800 mt-2">
                {data.summary.menuItems}
              </div>
            </div>

            <div className="border rounded-xl p-5">
              <div className="text-sm text-slate-500">Modelos Prisma</div>
              <div className="text-5xl font-black text-slate-800 mt-2">
                {data.summary.schemaModels}
              </div>
            </div>

            <div className="border rounded-xl p-5">
              <div className="text-sm text-slate-500">APIs dinámicas</div>
              <div className="text-5xl font-black text-slate-800 mt-2">
                {data.summary.dynamicApiRoutes}
              </div>
            </div>
          </div>

          <div className="border rounded-2xl p-6 mb-8 bg-slate-50">
            <h3 className="text-xl font-black text-slate-800 mb-4">
              Versiones detectadas
            </h3>

            <div className="grid grid-cols-5 gap-3">
              {Object.entries(data.versions).map(([key, value]) => (
                <div key={key} className="bg-white border rounded-xl p-4">
                  <div className="text-xs text-slate-500">{key}</div>
                  <div className="font-black text-slate-800 mt-1">{value}</div>
                </div>
              ))}
            </div>
          </div>

          <div className="flex flex-wrap gap-2 mb-6">
            {tabs.map((item) => (
              <button
                key={item.id}
                onClick={() => setTab(item.id)}
                className={`px-5 py-3 rounded-xl font-bold border ${
                  tab === item.id
                    ? "bg-green-600 text-white border-green-600"
                    : "bg-white text-slate-700"
                }`}
              >
                {item.label}
              </button>
            ))}
          </div>

          {tab === "issues" && (
            <div className="space-y-4">
              {data.issues.length === 0 && (
                <div className="border rounded-2xl p-8 text-green-700 bg-green-50 font-bold">
                  Sin problemas técnicos críticos detectados.
                </div>
              )}

              {data.issues.map((issue, index) => (
                <div key={index} className="border rounded-2xl p-6">
                  <div className="flex justify-between gap-4">
                    <div>
                      <div className="text-sm font-bold text-slate-500">
                        {issue.area}
                      </div>
                      <h3 className="text-xl font-black text-slate-800 mt-1">
                        {issue.message}
                      </h3>
                      <p className="text-slate-500 mt-2">
                        {issue.recommendation}
                      </p>
                    </div>

                    <span
                      className={`text-xs h-fit px-3 py-2 rounded-full font-black ${
                        issue.severity === "Crítica"
                          ? "bg-red-100 text-red-700"
                          : issue.severity === "Alta"
                          ? "bg-amber-100 text-amber-700"
                          : "bg-slate-100 text-slate-700"
                      }`}
                    >
                      {issue.severity}
                    </span>
                  </div>
                </div>
              ))}
            </div>
          )}

          {tab === "imports" && (
            <div className="grid grid-cols-2 gap-4">
              {data.imports.map((item) => (
                <div key={item.importPath} className="border rounded-xl p-4">
                  <div className="flex justify-between">
                    <div className="font-black text-slate-800">{item.name}</div>
                    <span
                      className={`text-xs px-2 py-1 rounded-full font-bold ${
                        item.ok ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"
                      }`}
                    >
                      {item.ok ? "OK" : "FALTA"}
                    </span>
                  </div>
                  <div className="text-xs text-slate-500 mt-2">{item.file}</div>
                </div>
              ))}
            </div>
          )}

          {tab === "menu" && (
            <div className="grid grid-cols-2 gap-6">
              <div className="border rounded-2xl p-6">
                <h3 className="text-xl font-black text-slate-800 mb-4">
                  Menú sin ruta en page.tsx
                </h3>

                <div className="space-y-2">
                  {data.menu.menuWithoutRoute.length === 0 && (
                    <div className="text-green-700 font-bold">
                      Todo el menú tiene ruta.
                    </div>
                  )}

                  {data.menu.menuWithoutRoute.map((item) => (
                    <div key={item} className="border rounded-xl p-3 text-sm">
                      {item}
                    </div>
                  ))}
                </div>
              </div>

              <div className="border rounded-2xl p-6">
                <h3 className="text-xl font-black text-slate-800 mb-4">
                  Rutas no visibles en menú
                </h3>

                <div className="space-y-2 max-h-96 overflow-auto">
                  {data.menu.routeWithoutMenu.map((item) => (
                    <div key={item} className="border rounded-xl p-3 text-sm">
                      {item}
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {tab === "files" && (
            <div className="grid grid-cols-2 gap-6">
              <div className="border rounded-2xl p-6">
                <h3 className="text-xl font-black text-slate-800 mb-4">
                  Archivos críticos
                </h3>

                <div className="space-y-2">
                  {data.files.critical.map((item) => (
                    <div key={item.file} className="flex justify-between border rounded-xl p-3 text-sm">
                      <span>{item.file}</span>
                      <span className={item.ok ? "text-green-700 font-bold" : "text-red-700 font-bold"}>
                        {item.ok ? "OK" : "FALTA"}
                      </span>
                    </div>
                  ))}
                </div>
              </div>

              <div className="border rounded-2xl p-6">
                <h3 className="text-xl font-black text-slate-800 mb-4">
                  Rutas API dinámicas
                </h3>

                <div className="space-y-2">
                  {data.files.dynamicApiRoutes.map((item) => (
                    <div key={item.routeFile} className="flex justify-between border rounded-xl p-3 text-sm">
                      <span>{item.routeFile}</span>
                      <span className={item.ok ? "text-green-700 font-bold" : "text-red-700 font-bold"}>
                        {item.ok ? "OK" : "FALTA"}
                      </span>
                    </div>
                  ))}
                </div>
              </div>
            </div>
          )}

          {tab === "prisma" && (
            <div className="grid grid-cols-3 gap-4">
              {data.prisma.delegateChecks.map((item) => (
                <div key={item.delegate} className="border rounded-xl p-4">
                  <div className="flex justify-between">
                    <div className="font-black text-slate-800">{item.delegate}</div>
                    <span
                      className={`text-xs px-2 py-1 rounded-full font-bold ${
                        item.ok ? "bg-green-100 text-green-700" : "bg-red-100 text-red-700"
                      }`}
                    >
                      {item.ok ? "OK" : "ERROR"}
                    </span>
                  </div>

                  <div className="text-4xl font-black text-slate-800 mt-3">
                    {item.count}
                  </div>

                  {item.error && (
                    <div className="text-xs text-red-600 mt-2">
                      {item.error}
                    </div>
                  )}
                </div>
              ))}
            </div>
          )}
        </>
      )}
    </section>
  );
}
