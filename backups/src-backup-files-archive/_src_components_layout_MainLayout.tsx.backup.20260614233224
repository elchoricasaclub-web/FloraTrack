function priorityClass(priority?: NavItem["priority"]) {
  if (priority === "critical") return "bg-red-100 text-red-700 border-red-200";
  if (priority === "high") return "bg-amber-100 text-amber-700 border-amber-200";
  if (priority === "system") return "bg-slate-100 text-slate-600 border-slate-200";
  return "bg-green-100 text-green-700 border-green-200";
}

function itemMatchesActive(item: NavItem, active: string) {
  return item.key === active || item.label === active || Boolean(item.aliases?.includes(active));
}

export default function MainLayout(props: MainLayoutProps) {
  const {
    children,

    activeSection,
    selectedSection,
    activeModule: activeModuleProp,
    selectedModule,
    currentModule,
    activeMenu,
    activeTab,

    setActiveSection,
    setSelectedSection,
    setActiveModule,
    setSelectedModule,
    setCurrentModule,
    setActiveMenu,
    setActiveTab,

    onSelectModule,
    onChangeModule,
    onMenuClick,
  } = props;

  const activeModule = String(
    activeSection ??
      selectedSection ??
      activeModuleProp ??
      selectedModule ??
      currentModule ??
      activeMenu ??
      activeTab ??
      "Dashboard"
  );

  const selectModule: Setter =
    setActiveSection ??
    setSelectedSection ??
    setActiveModule ??
    setSelectedModule ??
    setCurrentModule ??
    setActiveMenu ??
    setActiveTab ??
    onSelectModule ??
    onChangeModule ??
    onMenuClick ??
    (() => {});

  const defaultOpen = useMemo(() => {
    return navGroups.reduce<Record<string, boolean>>((acc, group) => {
      acc[group.id] = true;
      return acc;
    }, {});
  }, []);

  const [openGroups, setOpenGroups] = useState<Record<string, boolean>>(defaultOpen);
  const [search, setSearch] = useState("");

  const activeGroup = useMemo(() => {
    return navGroups.find((group) =>
      group.items.some((item) => itemMatchesActive(item, activeModule))
    );
  }, [activeModule]);

  const filteredGroups = useMemo(() => {
    const clean = search.trim().toLowerCase();

    if (!clean) return navGroups;

    return navGroups
      .map((group) => ({
        ...group,
        items: group.items.filter((item) => {
          return (
            item.label.toLowerCase().includes(clean) ||
            item.key.toLowerCase().includes(clean) ||
            item.description.toLowerCase().includes(clean) ||
            item.badge?.toLowerCase().includes(clean) ||
            item.aliases?.some((alias) => alias.toLowerCase().includes(clean))
          );
        }),
      }))
      .filter((group) => group.items.length > 0);
  }, [search]);

  function toggleGroup(groupId: string) {
    setOpenGroups((current) => ({
      ...current,
      [groupId]: !current[groupId],
    }));
  }

  return (
    <div className="min-h-screen bg-slate-100 text-slate-900">
      <aside className="fixed left-0 top-0 z-40 h-screen w-86 border-r border-slate-200 bg-white shadow-sm">
        <div className="flex h-full flex-col">
          <div className="border-b border-slate-100 p-6">
            <div className="flex items-center gap-3">
              <div className="flex h-12 w-12 items-center justify-center rounded-2xl bg-green-600 text-xl font-black text-white">
                F
              </div>

              <div>
                <div className="text-xl font-black leading-none text-slate-950">
                  FloraTrack
                </div>
                <div className="mt-1 text-xs font-bold uppercase tracking-widest text-green-600">
                  Enterprise Compliance
                </div>
              </div>
            </div>

            <div className="mt-5 rounded-2xl border bg-slate-50 p-4">
              <div className="text-xs font-bold uppercase tracking-widest text-slate-400">
                Módulo activo
              </div>
              <div className="mt-1 text-lg font-black text-slate-900">
                {activeModule}
              </div>
              <div className="mt-1 text-xs font-semibold text-slate-500">
                {activeGroup?.title ?? "Sistema"}
              </div>
            </div>

            <input
              value={search}
              onChange={(event) => setSearch(event.target.value)}
              placeholder="Buscar módulo..."
              className="mt-4 w-full rounded-2xl border border-slate-200 bg-white px-4 py-3 text-sm font-semibold outline-none focus:border-green-500"
            />
          </div>

          <nav className="flex-1 space-y-3 overflow-y-auto p-4">
            {filteredGroups.map((group) => {
              const isOpen = openGroups[group.id] ?? true;

              return (
                <div key={group.id} className="rounded-3xl border border-slate-100 bg-slate-50 p-3">
                  <button
                    onClick={() => toggleGroup(group.id)}
                    className="flex w-full items-center justify-between rounded-2xl px-3 py-3 text-left transition hover:bg-white"
                  >
                    <div className="flex items-center gap-3">
                      <div className="flex h-10 w-10 items-center justify-center rounded-2xl bg-white text-lg font-black text-green-700 shadow-sm">
                        {group.icon}
                      </div>

                      <div>
                        <div className="text-sm font-black text-slate-900">
                          {group.title}
                        </div>
                        <div className="text-xs font-medium text-slate-500">
                          {group.subtitle}
                        </div>
                      </div>
                    </div>

                    <div className="text-lg font-black text-slate-400">
                      {isOpen ? "−" : "+"}
                    </div>
                  </button>

                  {isOpen && (
                    <div className="mt-2 space-y-2">
                      {group.items.map((item) => {
                        const active = itemMatchesActive(item, activeModule);

                        return (
                          <button
                            key={item.key}
                            onClick={() => selectModule(item.key)}
                            className={`w-full rounded-2xl border p-4 text-left transition ${
                              active
                                ? "border-green-300 bg-green-50 shadow-sm"
                                : "border-transparent bg-white hover:border-slate-200 hover:shadow-sm"
                            }`}
                          >
                            <div className="flex items-start justify-between gap-3">
                              <div>
                                <div className={`text-sm font-black ${active ? "text-green-800" : "text-slate-900"}`}>
                                  {item.label}
                                </div>
                                <div className="mt-1 text-xs leading-relaxed text-slate-500">
                                  {item.description}
                                </div>
                              </div>

                              {item.badge && (
                                <span className={`shrink-0 rounded-full border px-2 py-1 text-[10px] font-black ${priorityClass(item.priority)}`}>
                                  {item.badge}
                                </span>
                              )}
                            </div>
                          </button>
                        );
                      })}
                    </div>
                  )}
                </div>
              );
            })}

            {filteredGroups.length === 0 && (
              <div className="rounded-3xl border bg-white p-6 text-center">
                <div className="text-lg font-black text-slate-900">
                  Sin resultados
                </div>
                <div className="mt-2 text-sm text-slate-500">
                  No encontré módulos con esa búsqueda.
                </div>
              </div>
            )}
          </nav>

          <div className="border-t border-slate-100 p-4">
            <div className="rounded-3xl bg-slate-950 p-4 text-white">
              <div className="text-xs font-bold uppercase tracking-widest text-green-300">
                Estado plataforma
              </div>
              <div className="mt-1 text-lg font-black">MVP Enterprise</div>
              <div className="mt-2 text-xs text-slate-300">
                Menú reorganizado por áreas críticas para operación, auditoría, SaaS e IA.
              </div>
            </div>
          </div>
        </div>
      </aside>

      <main className="min-h-screen pl-86">
        <header className="sticky top-0 z-30 border-b border-slate-200 bg-white/90 px-8 py-5 backdrop-blur">
          <div className="flex items-center justify-between gap-5">
            <div>
              <div className="text-xs font-black uppercase tracking-widest text-green-600">
                {activeGroup?.title ?? "FloraTrack"}
              </div>
              <h1 className="mt-1 text-3xl font-black text-slate-950">
                {activeModule}
              </h1>
            </div>

            <div className="flex items-center gap-3">
              <button className="rounded-2xl border bg-white px-5 py-3 text-sm font-black text-slate-700 shadow-sm">
                Audit Trail
              </button>

              <button className="rounded-2xl bg-green-600 px-5 py-3 text-sm font-black text-white shadow-sm">
                Nuevo Registro
              </button>
            </div>
          </div>
        </header>

        <section className="p-8">
          {children}
        </section>
      </main>
    </div>
  );
}
