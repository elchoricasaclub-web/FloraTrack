            <div>
              <h1 className="text-3xl font-black tracking-tight text-green-400">
                FloraTrack
              </h1>

              <p className="text-xs text-slate-400 mt-1 font-semibold">
                Enterprise Compliance Platform
              </p>

              <p className="text-[11px] text-slate-500 mt-1">
                GACP · GMP · LIMS · QMS · CSV · IA
              </p>
            </div>

            <div className="h-14 w-14 rounded-2xl bg-green-500/10 border border-green-500/30 flex items-center justify-center text-2xl">
              🌿
            </div>
          </div>

          <div className="mt-6 rounded-2xl border border-slate-800 bg-slate-900/70 p-4">
            <div className="text-[11px] uppercase tracking-widest text-slate-500 font-black">
              Sesión empresarial
            </div>

            <div className="text-lg font-black text-white mt-1">
              FloraTrack Enterprise
            </div>

            <div className="grid grid-cols-2 gap-3 mt-4 text-xs">
              <div className="rounded-xl bg-slate-950/80 border border-slate-800 p-3">
                <div className="text-slate-500">Usuario</div>
                <div className="font-black text-green-400 mt-1">Super Admin</div>
              </div>

              <div className="rounded-xl bg-slate-950/80 border border-slate-800 p-3">
                <div className="text-slate-500">Módulos</div>
                <div className="font-black text-green-400 mt-1">{totalModules}</div>
              </div>
            </div>
          </div>

          <div className="mt-5">
            <input
              value={search}
              onChange={(event) => setSearch(event.target.value)}
              placeholder="Buscar módulo..."
              className="w-full rounded-xl bg-slate-900 border border-slate-700 px-4 py-3 text-sm outline-none focus:border-green-500 text-white placeholder:text-slate-500"
            />
          </div>
        </div>

        <div className="flex-1 overflow-y-auto p-4 space-y-4">
          {filteredSections.length === 0 && (
            <div className="rounded-2xl border border-slate-800 bg-slate-900 p-5 text-sm text-slate-400">
              No se encontraron módulos con esa búsqueda.
            </div>
          )}

          {filteredSections.map((section, sectionIndex) => {
            const collapsed = collapsedSections[section.title];
            const activeInside = section.items.includes(activeModule);

            return (
              <div
                key={section.title}
                className={`rounded-2xl border ${
                  activeInside ? "border-green-500/50" : "border-slate-800"
                } bg-slate-900/80 overflow-hidden`}
              >
                <button
                  onClick={() => toggleSection(section.title)}
                  className="w-full text-left p-4 flex items-start justify-between gap-3 hover:bg-slate-800/80 transition"
                >
                  <div>
                    <div className={`h-1 w-20 rounded-full bg-gradient-to-r ${getSectionColor(sectionIndex)} mb-3`} />

                    <div className="text-[11px] font-black tracking-widest text-green-400">
                      {section.title}
                    </div>

                    <div className="text-xs text-slate-500 mt-1 leading-relaxed">
                      {section.subtitle}
                    </div>
                  </div>

                  <div className="text-slate-500 text-sm font-black">
                    {collapsed ? "+" : "−"}
                  </div>
                </button>

                {!collapsed && (
                  <div className="px-3 pb-3 space-y-1">
                    {section.items.map((item) => {
                      const isActive = item === activeModule;

                      return (
                        <button
                          key={`${section.title}-${item}`}
                          onClick={() => setActiveModule(item)}
                          className={`w-full flex items-center gap-3 text-left rounded-xl px-3 py-3 transition ${
                            isActive
                              ? "bg-green-500 text-white shadow-lg shadow-green-950/40"
                              : "text-slate-300 hover:bg-slate-800 hover:text-white"
                          }`}
                        >
                          <span className="text-lg">{getModuleIcon(item)}</span>

                          <span className="text-sm font-bold leading-tight">
                            {item}
                          </span>
                        </button>
                      );
                    })}
                  </div>
                )}
              </div>
            );
          })}
        </div>

        <div className="p-4 border-t border-slate-800 bg-slate-950">
          <div className="grid grid-cols-3 gap-2 text-center">
            <div className="rounded-xl bg-slate-900 border border-slate-800 p-3">
              <div className="text-[10px] text-slate-500">Estado</div>
              <div className="text-xs font-black text-green-400 mt-1">Online</div>
            </div>

            <div className="rounded-xl bg-slate-900 border border-slate-800 p-3">
              <div className="text-[10px] text-slate-500">Stack</div>
              <div className="text-xs font-black text-green-400 mt-1">Next</div>
            </div>

            <div className="rounded-xl bg-slate-900 border border-slate-800 p-3">
              <div className="text-[10px] text-slate-500">DB</div>
              <div className="text-xs font-black text-green-400 mt-1">Prisma</div>
            </div>
          </div>
        </div>
      </aside>

      <main className="ml-[380px] min-h-screen">
        <header className="sticky top-0 z-40 backdrop-blur-xl bg-white/80 border-b border-slate-200">
          <div className="px-8 py-5 flex items-center justify-between gap-6">
            <div>
              <div className="text-xs uppercase tracking-widest text-slate-400 font-black">
                Módulo activo
              </div>

              <h2 className="text-3xl font-black text-slate-800">
                {activeModule}
              </h2>
            </div>

            <div className="flex items-center gap-3">
              <button
                onClick={() => setActiveModule("Command Center")}
                className="border rounded-xl px-4 py-3 text-sm font-black text-slate-700 hover:bg-slate-50"
              >
                Command Center
              </button>

              <button
                onClick={() => setActiveModule("App Doctor")}
                className="border rounded-xl px-4 py-3 text-sm font-black text-slate-700 hover:bg-slate-50"
              >
                App Doctor
              </button>

              <button
                onClick={() => setActiveModule("Plan Maestro", "Expansión Servicios", "SaaS Multiempresa", "Seguridad RBAC", "Validación CSV Enterprise", "Inteligencia Regulatoria IA", "AI Gateway", "IA Privada Local")}
                className="bg-green-600 hover:bg-green-700 text-white rounded-xl px-4 py-3 text-sm font-black"
              >
                Plan Maestro
              </button>
            </div>
          </div>
        </header>

        <div className="p-8">
          {children}
        </div>
      </main>
    </div>
  );
}












