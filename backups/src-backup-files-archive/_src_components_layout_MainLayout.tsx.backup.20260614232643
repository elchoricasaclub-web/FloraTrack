function getModuleIcon(module: string) {
  const lower = module.toLowerCase();

  if (lower.includes("command") || lower.includes("control tower") || lower.includes("Dashboard", "UX Item Studio")) return "🏛️";
  if (lower.includes("doctor")) return "🛠️";
  if (lower.includes("audit") || lower.includes("auditor")) return "🔎";
  if (lower.includes("document") || lower.includes("sop") || lower.includes("registro")) return "📄";
  if (lower.includes("plan")) return "🗺️";
  if (lower.includes("alert")) return "🚨";
  if (lower.includes("calend")) return "📅";
  if (lower.includes("empresa") || lower.includes("usuario") || lower.includes("rol")) return "👥";
  if (lower.includes("predio") || lower.includes("cultivo") || lower.includes("cosecha")) return "🌱";
  if (lower.includes("genética") || lower.includes("genetica") || lower.includes("propag")) return "🧬";
  if (lower.includes("producción") || lower.includes("produccion") || lower.includes("batch")) return "🏭";
  if (lower.includes("coa") || lower.includes("muestra") || lower.includes("análisis") || lower.includes("analisis") || lower.includes("lims")) return "🧪";
  if (lower.includes("capa") || lower.includes("desvi") || lower.includes("riesgo") || lower.includes("calidad")) return "✅";
  if (lower.includes("licencia") || lower.includes("invima") || lower.includes("ica") || lower.includes("regulatorio")) return "⚖️";
  if (lower.includes("proveedor") || lower.includes("compra") || lower.includes("inventario")) return "📦";
  if (lower.includes("equipo") || lower.includes("calibr") || lower.includes("mantenimiento")) return "⚙️";
  if (lower.includes("ambient") || lower.includes("limpieza") || lower.includes("residuo")) return "🌡️";
  if (lower.includes("validación") || lower.includes("validacion") || lower.includes("alcoa") || lower.includes("csv")) return "🔐";
  if (lower.includes("cliente") || lower.includes("queja") || lower.includes("recall")) return "📣";
  if (lower.includes("ia")) return "🤖";

  return "▣";
}

function getSectionColor(index: number) {
  const colors = [
    "from-green-600 to-emerald-500",
    "from-slate-700 to-slate-500",
    "from-lime-600 to-green-500",
    "from-blue-700 to-blue-500",
    "from-cyan-700 to-cyan-500",
    "from-amber-600 to-yellow-500",
    "from-purple-700 to-purple-500",
    "from-orange-700 to-orange-500",
    "from-teal-700 to-teal-500",
    "from-indigo-700 to-indigo-500",
    "from-rose-700 to-rose-500",
    "from-fuchsia-700 to-fuchsia-500",
  ];

  return colors[index % colors.length];
}

export default function MainLayout({
  children,
  activeModule,
  setActiveModule,
}: MainLayoutProps) {
  const [search, setSearch] = useState("");
  const [collapsedSections, setCollapsedSections] = useState<Record<string, boolean>>({});

  const totalModules = sections.reduce((sum, section) => sum + section.items.length, 0);

  const filteredSections = useMemo(() => {
    const query = search.trim().toLowerCase();

    if (!query) {
      return sections;
    }

    return sections
      .map((section) => ({
        ...section,
        items: section.items.filter((item) => item.toLowerCase().includes(query)),
      }))
      .filter((section) => section.items.length > 0);
  }, [search]);

  function toggleSection(title: string) {
    setCollapsedSections((current) => ({
      ...current,
      [title]: !current[title],
    }));
  }

  return (
    <div className="min-h-screen bg-slate-100 text-slate-900">
      <aside className="fixed left-0 top-0 h-screen w-[380px] bg-slate-950 text-white flex flex-col border-r border-slate-800 z-50">
