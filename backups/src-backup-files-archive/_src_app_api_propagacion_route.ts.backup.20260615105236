function ensureStore() {
  if (!fs.existsSync(dataDir)) {
    fs.mkdirSync(dataDir, { recursive: true });
  }

  if (!fs.existsSync(dataFile)) {
    fs.writeFileSync(dataFile, JSON.stringify(seedPropagacion, null, 2), "utf8");
  }
}

function readRecords() {
  ensureStore();

  try {
    return JSON.parse(fs.readFileSync(dataFile, "utf8"));
  } catch {
    return [];
  }
}

function writeRecords(records: any[]) {
  ensureStore();
  fs.writeFileSync(dataFile, JSON.stringify(records, null, 2), "utf8");
}

export async function GET() {
  const records = readRecords();

  return NextResponse.json({
    ok: true,
    total: records.length,
    records
  });
}

export async function POST(request: Request) {
  const body = await request.json();
  const records = readRecords();

  const nextNumber = String(records.length + 1).padStart(3, "0");

  const record = {
    id: `PROP-${Date.now()}`,
    createdAt: new Date().toISOString(),
    nombre: String(body.nombre || `Nueva Propagación ${nextNumber}`),
    codigo: String(body.codigo || `PROP-${nextNumber}`),
    genetica: String(body.genetica || "Sin genética asignada"),
    area: String(body.area || "Propagación"),
    responsable: String(body.responsable || "Responsable GACP"),
    fase: String(body.fase || "Clones"),
    estado: String(body.estado || "Borrador"),
    riesgo: String(body.riesgo || "Medio"),
    cantidad: Number(body.cantidad || 0),
    avance: Number(body.avance || 0),
    evidencia: String(body.evidencia || "Evidencia pendiente"),
    nota: String(body.nota || "Registro creado desde el módulo Propagación.")
  };

  records.unshift(record);
  writeRecords(records);

  return NextResponse.json({
    ok: true,
    record,
    records
  });
}

export async function PATCH(request: Request) {
  const body = await request.json();
  const records = readRecords();

  const updated = records.map((item: any) => {
    if (item.id !== body.id) return item;

    return {
      ...item,
      ...body,
      updatedAt: new Date().toISOString()
    };
  });

  writeRecords(updated);

  return NextResponse.json({
    ok: true,
    records: updated
  });
}
