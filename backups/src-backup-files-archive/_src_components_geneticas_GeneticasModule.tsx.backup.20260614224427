"use client";

import { useEffect, useState } from "react";

type Genetic = {
  id: string;
  name: string;
  origin: string | null;
  type: string | null;
  status: string;
  _count?: {
    crops: number;
  };
};

const emptyForm = {
  id: "",
  name: "",
  origin: "",
  type: "",
  status: "Autorizada",
};

export default function GeneticasModule() {
  const [genetics, setGenetics] = useState<Genetic[]>([]);
  const [form, setForm] = useState(emptyForm);
  const [showForm, setShowForm] = useState(false);
  const [message, setMessage] = useState("");
  const [search, setSearch] = useState("");

  async function loadGenetics() {
    const response = await fetch("/api/genetics", { cache: "no-store" });
    const result = await response.json();

    if (!result.ok) {
      setMessage(result.error || "Error cargando genéticas");
      return;
    }

    setGenetics(result.data);
    setMessage("Genéticas cargadas desde base de datos.");
  }

  useEffect(() => {
    loadGenetics();
  }, []);

  function updateField(name: string, value: string) {
    setForm((current) => ({ ...current, [name]: value }));
  }

  function resetForm() {
    setForm(emptyForm);
    setShowForm(false);
  }

  async function saveGenetic() {
    const response = await fetch("/api/genetics", {
      method: form.id ? "PUT" : "POST",
      headers: { "Content-Type": "application/json" },
      body: JSON.stringify(form),
    });

    const result = await response.json();

    if (!result.ok) {
      setMessage(result.error || "Error guardando genética");
      return;
    }

    setMessage(form.id ? "Genética actualizada." : "Genética creada.");
    resetForm();
    loadGenetics();
  }

  function editGenetic(genetic: Genetic) {
    setForm({
      id: genetic.id,
      name: genetic.name || "",
      origin: genetic.origin || "",
      type: genetic.type || "",
      status: genetic.status || "Autorizada",
    });

    setShowForm(true);
  }

  async function deleteGenetic(genetic: Genetic) {
    const confirmed = confirm("¿Eliminar genética? Si tiene cultivos relacionados puede fallar.");

    if (!confirmed) {
      return;
    }

    const response = await fetch(`/api/genetics?id=${genetic.id}`, { method: "DELETE" });
    const result = await response.json();

    if (!result.ok) {
      setMessage(result.error || "No fue posible eliminar la genética.");
      return;
    }

    setMessage("Genética eliminada.");
    loadGenetics();
  }

  const filteredGenetics = genetics.filter((genetic) =>
    Object.values(genetic).join(" ").toLowerCase().includes(search.toLowerCase())
  );

  return (
    <section className="bg-white rounded-2xl shadow p-8">
      <div className="flex justify-between items-start gap-6 mb-8">
        <div>
          <h2 className="text-4xl font-bold text-slate-800">Genéticas</h2>
          <p className="text-slate-500 mt-2 max-w-2xl leading-relaxed">
            Genéticas conectadas a base de datos real con origen, tipo, estado y cultivos asociados.
          </p>
        </div>

        <button
          onClick={() => {
            setShowForm(true);
            setForm(emptyForm);
          }}
          className="bg-green-600 hover:bg-green-700 text-white px-6 py-4 rounded-xl shadow text-lg font-bold"
        >
          + Nueva Genética
        </button>
      </div>

      {message && (
        <div className="bg-green-50 border border-green-200 text-green-700 rounded-xl p-4 mb-8 font-semibold">
          {message}
        </div>
      )}

      <div className="grid grid-cols-4 gap-4 mb-8">
        <div className="border rounded-xl p-4">
          <div className="text-sm text-slate-500">Genéticas</div>
          <div className="text-3xl font-bold text-slate-800">{genetics.length}</div>
        </div>
        <div className="border rounded-xl p-4">
          <div className="text-sm text-slate-500">Autorizadas</div>
          <div className="text-3xl font-bold text-green-600">{genetics.filter((genetic) => genetic.status === "Autorizada").length}</div>
        </div>
        <div className="border rounded-xl p-4">
          <div className="text-sm text-slate-500">En evaluación</div>
          <div className="text-3xl font-bold text-yellow-600">{genetics.filter((genetic) => genetic.status === "En evaluación").length}</div>
        </div>
        <div className="border rounded-xl p-4">
          <div className="text-sm text-slate-500">Cultivos</div>
          <div className="text-3xl font-bold text-slate-800">{genetics.reduce((sum, genetic) => sum + Number(genetic._count?.crops || 0), 0)}</div>
        </div>
      </div>

      <div className="flex gap-3 mb-6">
        <input value={search} onChange={(e) => setSearch(e.target.value)} placeholder="Buscar genética..." className="flex-1 border rounded-xl px-4 py-3 text-slate-700" />
        <button onClick={loadGenetics} className="px-5 py-3 rounded-xl border bg-white text-slate-700 font-semibold">Actualizar</button>
      </div>

      {showForm && (
        <div className="border rounded-2xl p-6 mb-8 bg-slate-50">
          <h3 className="text-2xl font-bold text-slate-800 mb-5">{form.id ? "Editar genética" : "Nueva genética"}</h3>

          <div className="grid grid-cols-2 gap-4">
            <input className="border rounded-xl px-4 py-3" placeholder="Nombre genética" value={form.name} onChange={(e) => updateField("name", e.target.value)} />
            <input className="border rounded-xl px-4 py-3" placeholder="Origen" value={form.origin} onChange={(e) => updateField("origin", e.target.value)} />

            <select className="border rounded-xl px-4 py-3" value={form.type} onChange={(e) => updateField("type", e.target.value)}>
              <option value="">Seleccione tipo</option>
              <option value="Psicoactiva">Psicoactiva</option>
              <option value="No psicoactiva">No psicoactiva</option>
              <option value="CBD dominante">CBD dominante</option>
              <option value="Balanceada">Balanceada</option>
              <option value="Cannabis medicinal">Cannabis medicinal</option>
            </select>

            <select className="border rounded-xl px-4 py-3" value={form.status} onChange={(e) => updateField("status", e.target.value)}>
              <option value="Autorizada">Autorizada</option>
              <option value="En evaluación">En evaluación</option>
              <option value="Bloqueada">Bloqueada</option>
            </select>
          </div>

          <div className="flex justify-end gap-3 mt-6">
            <button onClick={resetForm} className="px-5 py-3 rounded-xl border text-slate-600 bg-white">Cancelar</button>
            <button onClick={saveGenetic} className="px-5 py-3 rounded-xl bg-green-600 text-white font-semibold">Guardar genética</button>
          </div>
        </div>
      )}

      <div className="border rounded-2xl overflow-hidden">
        <table className="w-full text-left">
          <thead className="bg-slate-100">
            <tr>
              <th className="px-4 py-3 text-sm text-slate-600">Genética</th>
              <th className="px-4 py-3 text-sm text-slate-600">Origen</th>
              <th className="px-4 py-3 text-sm text-slate-600">Tipo</th>
              <th className="px-4 py-3 text-sm text-slate-600">Cultivos</th>
              <th className="px-4 py-3 text-sm text-slate-600">Estado</th>
              <th className="px-4 py-3 text-sm text-slate-600">Acciones</th>
            </tr>
          </thead>
          <tbody>
            {filteredGenetics.map((genetic) => (
              <tr key={genetic.id} className="border-t">
                <td className="px-4 py-3 font-semibold">{genetic.name}</td>
                <td className="px-4 py-3">{genetic.origin || "-"}</td>
                <td className="px-4 py-3">{genetic.type || "-"}</td>
                <td className="px-4 py-3">{genetic._count?.crops || 0}</td>
                <td className="px-4 py-3">{genetic.status}</td>
                <td className="px-4 py-3">
                  <button onClick={() => editGenetic(genetic)} className="text-blue-600 font-semibold mr-4">Editar</button>
                  <button onClick={() => deleteGenetic(genetic)} className="text-red-600 font-semibold">Eliminar</button>
                </td>
              </tr>
            ))}
          </tbody>
        </table>
      </div>
    </section>
  );
}
