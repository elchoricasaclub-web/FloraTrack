"use client";

import { useEffect } from "react";

export default function GlobalUiSanitizer() {
  useEffect(() => {
    function cleanOldUi() {
      const elements = Array.from(document.querySelectorAll("div, section, aside")) as HTMLElement[];

      for (const element of elements) {
        if (element.closest("[data-global-required-save-v3='true']")) continue;
        if (element.closest("[data-app-status-window='true']")) continue;

        const text = element.textContent || "";
        const style = window.getComputedStyle(element);

        if (
          style.position === "fixed" &&
          text.includes("Guardado seguro") &&
          text.includes("Guardar avance actual")
        ) {
          element.style.display = "none";
        }
      }
    }

    cleanOldUi();

    const interval = window.setInterval(cleanOldUi, 1500);

    return () => {
      window.clearInterval(interval);
    };
  }, []);

  return null;
}
