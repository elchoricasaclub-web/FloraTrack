"use client";

import { useState } from "react";

export default function SaveProgressTestPage() {
  const [message, setMessage] = useState("");

  async function saveProgress() {
    setMessage("Guardando...");

    const response = await fetch("/api/progress-records", {
      method: "POST",
      cache: "no-store",
    });

    const data = await response.json();

    if (data.ok) {
      setMessage("AVANCE GUARDADO CORRECTAMENTE. Ahora abre Registros de Avance.");
    } else {
      setMessage("No se pudo guardar.");
    }
  }

  return (
    <main className="min-h-screen bg-slate-100 p-8">
      <section className="mx-auto max-w-4xl rounded-3xl bg-white p-10 shadow">
        <div className="text-sm font-black uppercase tracking-widest text-green-600">
          FloraTrack Test
        </div>

        <h1 className="mt-3 text-5xl font-black text-slate-900">
          Prueba Guardar Avance
        </h1>

        <p className="mt-4 text-slate-500">
          Presiona el botón para guardar un avance real en archivo local.
        </p>

        <button
          onClick={saveProgress}
          className="mt-8 rounded-2xl bg-green-600 px-8 py-5 text-xl font-black text-white hover:bg-green-700"
        >
          Guardar avance de prueba
        </button>

        {message && (
          <div className="mt-8 rounded-2xl bg-slate-950 p-6 text-xl font-black text-white">
            {message}
          </div>
        )}

        <a
          href="/progress-records"
          className="mt-6 inline-block rounded-2xl border px-6 py-4 font-black text-slate-700"
        >
          Abrir Registros de Avance
        </a>
      </section>
    </main>
  );
}
