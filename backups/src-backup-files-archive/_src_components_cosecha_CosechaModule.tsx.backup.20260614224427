"use client";

import { useEffect, useState } from "react";
import DbCrudModule from "../ui/DbCrudModule";

type Option = {
  label: string;
  value: string;
};

export default function CosechaModule() {
  const [crops, setCrops] = useState<Option[]>([]);

  useEffect(() => {
    async function loadOptions() {
      const response = await fetch("/api/db/crops", { cache: "no-store" });
      const result = await response.json();

      if (result.ok) {
        setCrops(
          result.data.map((item: any) => ({
            label: item.code,
            value: item.id,
          }))
        );
      }
    }

    loadOptions();
  }, []);

  return (
    <DbCrudModule
      title="Cosecha"
      description="Cosechas conectadas a base de datos real con cultivo origen, peso húmedo, estado y trazabilidad hacia muestras."
      apiPath="/api/db/harvests"
      buttonLabel="Nueva Cosecha"
      icon="🌾"
      emptyForm={{
        id: "",
        code: "",
        wetWeight: "",
        status: "Pendiente",
        cropId: "",
      }}
      fields={[
        { name: "code", label: "Código cosecha", required: true },
        { name: "wetWeight", label: "Peso húmedo kg", type: "number" },
        {
          name: "status",
          label: "Estado",
          type: "select",
          options: [
            { label: "Pendiente", value: "Pendiente" },
            { label: "En secado", value: "En secado" },
            { label: "Aprobado", value: "Aprobado" },
            { label: "Bloqueado", value: "Bloqueado" },
          ],
        },
        {
          name: "cropId",
          label: "Cultivo",
          type: "select",
          options: crops,
        },
      ]}
      columns={[
        { label: "Código", accessor: "code" },
        { label: "Peso húmedo", accessor: "wetWeight" },
        { label: "Cultivo", accessor: "crop.code" },
        { label: "Genética", accessor: "crop.genetic.name" },
      ]}
    />
  );
}
